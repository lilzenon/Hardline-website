# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - only commit .env.example

# Database Configuration
DB_CLIENT=pg
DB_HOST=your-database-host
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_PORT=5432
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# App Configuration
DEFAULT_DOMAIN=your-domain.com
ADMIN_EMAIL=admin@your-domain.com
SITE_NAME=YOUR_SITE_NAME
REPORT_EMAIL=reports@your-domain.com
PORT=3000
NODE_ENV=production

# Security Secrets (GENERATE NEW VALUES)
JWT_SECRET=generate-a-secure-jwt-secret-here
SESSION_SECRET=generate-a-secure-session-secret-here

# Redis Configuration
REDIS_ENABLED=false
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Session Configuration
SESSION_NAME=your-app.sid
SESSION_TTL=43200

# Registration & Security
DISALLOW_REGISTRATION=false
CUSTOM_DOMAIN_USE_HTTPS=true

# Mail Configuration
MAIL_ENABLED=false
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@domain.com
MAIL_PASS=your-email-password

# Generate secrets using:
# JWT_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
