<!-- Drops JavaScript -->
<script>
let dropToDelete = null;

// Create drop function
function createDrop() {
    console.log('Create drop button clicked');

    const modal = document.getElementById('create-drop-dialog');
    if (modal) {
        modal.classList.remove('hidden');

        // Focus on the title input
        setTimeout(() => {
            const titleInput = document.getElementById('drop-title');
            if (titleInput) {
                titleInput.focus();
            }
        }, 100);
    } else {
        window.location.href = '/#create-drop';
    }
}

// Copy drop link to clipboard with visual feedback
async function copyDropLink(url, buttonElement) {
    try {
        await navigator.clipboard.writeText(url);

        // Visual feedback - change button text temporarily
        const textElement = buttonElement.querySelector('.copy-text');
        const originalText = textElement.textContent;

        textElement.textContent = 'Copied!';
        buttonElement.classList.add('bg-green-50', 'border-green-300', 'text-green-700');
        buttonElement.classList.remove('bg-white', 'border-gray-300', 'text-gray-700');

        // Reset after 2 seconds
        setTimeout(() => {
            textElement.textContent = originalText;
            buttonElement.classList.remove('bg-green-50', 'border-green-300', 'text-green-700');
            buttonElement.classList.add('bg-white', 'border-gray-300', 'text-gray-700');
        }, 2000);

        // Show toast notification if available
        if (typeof showToast === 'function') {
            showToast('Drop link copied to clipboard!', 'success');
        }
    } catch (err) {
        console.error('Failed to copy link:', err);

        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = url;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);

        if (typeof showToast === 'function') {
            showToast('Drop link copied to clipboard!', 'success');
        }
    }
}

// Delete drop function
function deleteDrop(dropId, dropTitle) {
    console.log('Delete drop clicked:', dropId, dropTitle);
    dropToDelete = dropId;

    const titleElement = document.getElementById('dropTitle');
    const modalElement = document.getElementById('deleteModal');

    if (titleElement) {
        titleElement.textContent = dropTitle;
    }

    if (modalElement) {
        modalElement.classList.remove('hidden');
    }
}

// Simple event handlers setup
function setupEventHandlers() {
    console.log('Setting up event handlers');

    // Create Drop button handlers
    const createDropButtons = document.querySelectorAll('.create-drop-btn, [data-action="create-drop"]');
    console.log('Found create drop buttons:', createDropButtons.length);

    createDropButtons.forEach((button) => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Create drop button clicked');
            createDrop();
        });
    });

    // Delete Drop button handlers
    const deleteDropButtons = document.querySelectorAll('.delete-drop-btn, [data-action="delete-drop"]');
    console.log('Found delete drop buttons:', deleteDropButtons.length);

    deleteDropButtons.forEach((button) => {
        const dropId = button.getAttribute('data-drop-id');
        const dropTitle = button.getAttribute('data-drop-title');

        button.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Delete drop button clicked:', dropId, dropTitle);
            deleteDrop(dropId, dropTitle);
        });
    });

    console.log('Event handlers setup complete');
}

// Initialize event handlers when DOM is ready
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM Content Loaded');
    setupEventHandlers();
});

// Also setup handlers if DOM is already loaded
if (document.readyState === 'loading') {
    console.log('DOM still loading, waiting for DOMContentLoaded');
} else {
    console.log('DOM already loaded, setting up handlers immediately');
    setupEventHandlers();
}

// Confirm delete handler
document.getElementById('confirmDelete').addEventListener('click', async function() {
    console.log('Confirm delete clicked:', dropToDelete);

    if (!dropToDelete) {
        console.log('No drop to delete');
        return;
    }

    try {
        console.log('Sending DELETE request to:', `/api/drops/${dropToDelete}`);

        const response = await fetch(`/api/drops/${dropToDelete}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        });

        console.log('Response status:', response.status);

        if (response.ok) {
            const result = await response.json();
            console.log('Delete successful:', result);
            showToast('Drop deleted successfully!', 'success');
            // Reload the page to update the list
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            const error = await response.json();
            console.log('Delete failed:', error);
            showToast(error.message || 'Failed to delete drop', 'error');
        }
    } catch (error) {
        console.log('Delete error:', error);
        showToast('Failed to delete drop', 'error');
    }

    document.getElementById('deleteModal').classList.add('hidden');
    dropToDelete = null;
});

// Cancel delete handler
document.getElementById('cancelDelete').addEventListener('click', function() {
    console.log('Delete cancelled');
    document.getElementById('deleteModal').classList.add('hidden');
    dropToDelete = null;
});

// Close modal when clicking outside
document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) {
        console.log('Modal closed by clicking outside');
        this.classList.add('hidden');
        dropToDelete = null;
    }
});

// Close modal with Escape key
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('deleteModal');
        if (modal && !modal.classList.contains('hidden')) {
            console.log('Modal closed with Escape key');
            modal.classList.add('hidden');
            dropToDelete = null;
        }
    }
});

// Toast notification function
function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = `fixed top-4 right-4 px-4 py-2 rounded-md shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
    }`;
    toast.textContent = message;
    document.body.appendChild(toast);

    setTimeout(() => {
        document.body.removeChild(toast);
    }, 3000);
}

// Note: Using local createDrop function instead of main.js to avoid conflicts
