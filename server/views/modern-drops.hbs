<!-- Modern Delete Confirmation Modal with Glassmorphism -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm overflow-y-auto h-full w-full hidden z-50 flex items-center justify-center p-4">
    <div class="relative w-full max-w-md mx-auto">
        <!-- Glassmorphism Modal -->
        <div class="bg-white bg-opacity-95 backdrop-blur-xl rounded-2xl shadow-2xl border border-white border-opacity-20 p-6 sm:p-8">
            <!-- Header with Warning Icon -->
            <div class="flex items-center justify-center mb-6">
                <div class="w-16 h-16 bg-gradient-to-br from-red-100 to-red-200 rounded-full flex items-center justify-center shadow-lg">
                    <svg class="w-8 h-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
                    </svg>
                </div>
            </div>

            <!-- Content -->
            <div class="text-center mb-8">
                <h3 class="text-xl font-semibold text-gray-900 mb-3">Delete Drop?</h3>
                <p class="text-gray-600 leading-relaxed">
                    Are you sure you want to delete
                    <span class="font-semibold text-gray-900">"<span id="dropTitle"></span>"</span>?
                </p>
                <p class="text-sm text-red-600 mt-2 font-medium">
                    ⚠️ This action cannot be undone
                </p>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-3">
                <button id="cancelDelete"
                        class="flex-1 px-6 py-3 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 transition-colors duration-200">
                    Cancel
                </button>
                <button id="confirmDelete"
                        class="flex-1 px-6 py-3 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 transition-colors duration-200 shadow-sm">
                    <span class="flex items-center justify-center">
                        <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Delete Drop
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Drops JavaScript - Integrated with Existing System -->
<script>
let dropToDelete = null;

// Create drop function - opens the modern modal
function createDrop() {
    console.log('🎯 Create drop button clicked');
    const modal = document.getElementById('create-drop-dialog');
    console.log('🔍 Modal element found:', modal);

    if (modal) {
        modal.classList.remove('hidden');
        console.log('✅ Modal shown, classes:', modal.className);

        // Focus on the title input
        setTimeout(() => {
            const titleInput = document.getElementById('drop-title');
            if (titleInput) {
                titleInput.focus();
                console.log('✅ Title input focused');
            } else {
                console.log('❌ Title input not found');
            }
        }, 100);
    } else {
        console.log('❌ Modal not found, redirecting to fallback');
        // Fallback: redirect to homepage with create dialog
        window.location.href = '/#create-drop';
    }
}

// Copy drop link to clipboard with visual feedback
async function copyDropLink(url, buttonElement) {
    try {
        await navigator.clipboard.writeText(url);

        // Visual feedback - change button text temporarily
        const textElement = buttonElement.querySelector('.copy-text');
        const originalText = textElement.textContent;

        textElement.textContent = 'Copied!';
        buttonElement.classList.add('bg-green-50', 'border-green-300', 'text-green-700');
        buttonElement.classList.remove('bg-white', 'border-gray-300', 'text-gray-700');

        // Reset after 2 seconds
        setTimeout(() => {
            textElement.textContent = originalText;
            buttonElement.classList.remove('bg-green-50', 'border-green-300', 'text-green-700');
            buttonElement.classList.add('bg-white', 'border-gray-300', 'text-gray-700');
        }, 2000);

        // Show toast notification if available
        if (typeof showToast === 'function') {
            showToast('Drop link copied to clipboard!', 'success');
        }
    } catch (err) {
        console.error('Failed to copy link:', err);

        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = url;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);

        if (typeof showToast === 'function') {
            showToast('Drop link copied to clipboard!', 'success');
        }
    }
}

function deleteDrop(dropId, dropTitle) {
    console.log('🗑️ Delete drop clicked:', { dropId, dropTitle });
    dropToDelete = dropId;

    const titleElement = document.getElementById('dropTitle');
    const modalElement = document.getElementById('deleteModal');

    console.log('🔍 Title element found:', titleElement);
    console.log('🔍 Modal element found:', modalElement);

    if (titleElement) {
        titleElement.textContent = dropTitle;
        console.log('✅ Title set to:', dropTitle);
    }

    if (modalElement) {
        modalElement.classList.remove('hidden');
        console.log('✅ Modal shown');
    } else {
        console.log('❌ Modal not found');
    }
}

document.getElementById('confirmDelete').addEventListener('click', async function() {
    console.log('🔥 Confirm delete clicked, dropToDelete:', dropToDelete);

    if (!dropToDelete) {
        console.log('❌ No drop to delete');
        return;
    }

    try {
        console.log('🚀 Sending DELETE request to:', `/api/drops/${dropToDelete}`);

        const response = await fetch(`/api/drops/${dropToDelete}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        });

        console.log('📡 Response status:', response.status);
        console.log('📡 Response ok:', response.ok);

        if (response.ok) {
            const result = await response.json();
            console.log('✅ Delete successful:', result);
            showToast('Drop deleted successfully!', 'success');
            // Reload the page to update the list
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            const error = await response.json();
            console.log('❌ Delete failed:', error);
            showToast(error.message || 'Failed to delete drop', 'error');
        }
    } catch (error) {
        console.log('🚨 Delete error:', error);
        showToast('Failed to delete drop', 'error');
    }

    document.getElementById('deleteModal').classList.add('hidden');
    dropToDelete = null;
});

document.getElementById('cancelDelete').addEventListener('click', function() {
    console.log('❌ Delete cancelled');
    document.getElementById('deleteModal').classList.add('hidden');
    dropToDelete = null;
});

// Close modal when clicking outside
document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) {
        console.log('🚪 Modal closed by clicking outside');
        this.classList.add('hidden');
        dropToDelete = null;
    }
});

// Close modal with Escape key
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        const modal = document.getElementById('deleteModal');
        if (modal && !modal.classList.contains('hidden')) {
            console.log('⌨️ Modal closed with Escape key');
            modal.classList.add('hidden');
            dropToDelete = null;
        }
    }
});

// Toast notification function
function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = `fixed top-4 right-4 px-4 py-2 rounded-md shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
    }`;
    toast.textContent = message;
    document.body.appendChild(toast);

    setTimeout(() => {
        document.body.removeChild(toast);
    }, 3000);
}

// Note: Using local createDrop function instead of main.js to avoid conflicts
</script>

