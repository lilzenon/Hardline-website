<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="format-detection" content="telephone=no">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    
    <!-- SEO Meta Tags -->
    <title>{{title}}</title>
    <meta name="description" content="{{#if metaTags.description}}{{metaTags.description}}{{else}}Discover upcoming live music events, concerts, and exclusive experiences on BOUNCE2BOUNCE.{{/if}}">
    <meta name="keywords" content="{{#if metaTags.keywords}}{{metaTags.keywords}}{{else}}live music events, concerts, tickets, artists, venues{{/if}}">
    <meta name="author" content="BOUNCE2BOUNCE">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <link rel="canonical" href="https://{{default_domain}}/events">
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="{{title}}">
    <meta property="og:description" content="{{#if metaTags.description}}{{metaTags.description}}{{else}}Discover upcoming live music events and concerts{{/if}}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://{{default_domain}}/events">
    <meta property="og:site_name" content="BOUNCE2BOUNCE">
    <meta property="og:image" content="https://{{default_domain}}/images/bounce-logo.svg">
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@bounce2bounce">
    <meta name="twitter:title" content="{{title}}">
    <meta name="twitter:description" content="{{#if metaTags.description}}{{metaTags.description}}{{else}}Discover upcoming live music events{{/if}}">
    <meta name="twitter:image" content="https://{{default_domain}}/images/bounce-logo.svg">
    
    <!-- Structured Data -->
    {{#if eventsListStructuredData}}
    <script type="application/ld+json">
    {{{eventsListStructuredData}}}
    </script>
    {{/if}}
    
    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://{{default_domain}}/"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Events",
                "item": "https://{{default_domain}}/events"
            }
        ]
    }
    </script>
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/css/figma-home.css">
    <link rel="stylesheet" href="/css/breadcrumb.css">
    <link rel="stylesheet" href="/css/event-glassmorphism.css">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    
    <!-- Theme -->
    <meta name="theme-color" content="#000000">
</head>
<body style="font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); min-height: 100vh; color: white;">
    
    <!-- Main Content -->
    <main class="events-listing-container" style="max-width: 1200px; margin: 0 auto; padding: 2rem 1rem;">
        
        <!-- Header Section -->
        <header class="events-header" style="text-align: center; margin-bottom: 3rem;">
            <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; background: linear-gradient(135deg, #ffffff 0%, #cccccc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                Live Music Events
            </h1>
            <p style="font-size: 1.125rem; color: rgba(255, 255, 255, 0.8); max-width: 600px; margin: 0 auto;">
                Discover exclusive live music experiences, connect with artists, and get tickets to unforgettable events.
            </p>
            {{#if totalEvents}}
            <p style="margin-top: 1rem; color: rgba(255, 255, 255, 0.6);">
                {{totalEvents}} {{#if (eq totalEvents 1)}}event{{else}}events{{/if}} available
            </p>
            {{/if}}
        </header>
        
        <!-- Search Section -->
        <section class="search-section" style="margin-bottom: 3rem;">
            <form action="/events" method="GET" style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; align-items: center;">
                <input 
                    type="text" 
                    name="q" 
                    placeholder="Search events, artists..." 
                    value="{{searchQuery}}"
                    style="padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.2); background: rgba(255, 255, 255, 0.1); color: white; backdrop-filter: blur(10px); min-width: 250px;"
                >
                <button 
                    type="submit"
                    style="padding: 0.75rem 1.5rem; border-radius: 8px; border: none; background: linear-gradient(135deg, #007bff 0%, #0056b3 100%); color: white; font-weight: 600; cursor: pointer; transition: transform 0.2s ease;"
                    onmouseover="this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.transform='translateY(0)'"
                >
                    Search Events
                </button>
            </form>
        </section>
        
        <!-- Events Grid -->
        <section class="events-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            {{#each events}}
            <article class="event-card" style="background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 16px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                
                {{#if this.cover_image}}
                <div class="event-image" style="width: 100%; height: 200px; background-image: url('{{this.cover_image}}'); background-size: cover; background-position: center;"></div>
                {{/if}}
                
                <div class="event-content" style="padding: 1.5rem;">
                    <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; color: white;">
                        <a href="/event/{{this.slug}}" style="color: inherit; text-decoration: none;">
                            {{this.title}}
                        </a>
                    </h2>
                    
                    {{#if this.artist_name}}
                    <p style="color: rgba(255, 255, 255, 0.8); margin-bottom: 0.5rem; font-weight: 500;">
                        {{this.artist_name}}
                    </p>
                    {{/if}}
                    
                    {{#if this.event_date}}
                    <p style="color: rgba(255, 255, 255, 0.7); margin-bottom: 0.5rem; font-size: 0.875rem;">
                        📅 {{this.event_date}}
                    </p>
                    {{/if}}
                    
                    {{#if this.event_address}}
                    <p style="color: rgba(255, 255, 255, 0.7); margin-bottom: 1rem; font-size: 0.875rem;">
                        📍 {{this.event_address}}
                    </p>
                    {{/if}}
                    
                    {{#if this.description}}
                    <p style="color: rgba(255, 255, 255, 0.8); margin-bottom: 1rem; font-size: 0.875rem; line-height: 1.5;">
                        {{#if (gt this.description.length 120)}}
                            {{substring this.description 0 120}}...
                        {{else}}
                            {{this.description}}
                        {{/if}}
                    </p>
                    {{/if}}
                    
                    <a 
                        href="/event/{{this.slug}}" 
                        style="display: inline-block; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #007bff 0%, #0056b3 100%); color: white; text-decoration: none; border-radius: 8px; font-weight: 600; transition: transform 0.2s ease;"
                        onmouseover="this.style.transform='translateY(-2px)'"
                        onmouseout="this.style.transform='translateY(0)'"
                    >
                        View Event
                    </a>
                </div>
            </article>
            {{/each}}
        </section>
        
        <!-- No Events Message -->
        {{#unless events}}
        <section class="no-events" style="text-align: center; padding: 3rem 1rem;">
            <h2 style="font-size: 1.5rem; color: rgba(255, 255, 255, 0.8); margin-bottom: 1rem;">
                {{#if searchQuery}}
                    No events found for "{{searchQuery}}"
                {{else}}
                    No events available
                {{/if}}
            </h2>
            <p style="color: rgba(255, 255, 255, 0.6); margin-bottom: 2rem;">
                {{#if searchQuery}}
                    Try adjusting your search terms or browse all events.
                {{else}}
                    Check back soon for upcoming live music events and experiences.
                {{/if}}
            </p>
            {{#if searchQuery}}
            <a 
                href="/events" 
                style="display: inline-block; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #007bff 0%, #0056b3 100%); color: white; text-decoration: none; border-radius: 8px; font-weight: 600;"
            >
                Browse All Events
            </a>
            {{/if}}
        </section>
        {{/unless}}
        
        <!-- Internal Links for SEO -->
        <section class="internal-links" style="margin-top: 4rem; padding: 2rem; background: rgba(255, 255, 255, 0.05); border-radius: 16px; text-align: center;">
            <h3 style="font-size: 1.25rem; margin-bottom: 1rem; color: white;">Explore More</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;">
                <a href="/" style="color: rgba(255, 255, 255, 0.8); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 8px; transition: background 0.2s ease;">
                    🏠 Homepage
                </a>
                <a href="/dashboard" style="color: rgba(255, 255, 255, 0.8); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 8px; transition: background 0.2s ease;">
                    📊 Dashboard
                </a>
                <a href="/dashboard/events/create" style="color: rgba(255, 255, 255, 0.8); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 8px; transition: background 0.2s ease;">
                    ➕ Create Event
                </a>
            </div>
        </section>
        
    </main>
    
    <!-- Footer -->
    <footer style="text-align: center; padding: 2rem 1rem; color: rgba(255, 255, 255, 0.6); border-top: 1px solid rgba(255, 255, 255, 0.1); margin-top: 4rem;">
        <p>&copy; 2024 BOUNCE2BOUNCE. Connecting artists with fans through exclusive live music experiences.</p>
    </footer>

    <!-- Hidden Breadcrumb Navigation for SEO (positioned at bottom) -->
    <nav class="breadcrumb-container" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link">Home</a>
                <span class="breadcrumb-separator" aria-hidden="true">/</span>
            </li>
            <li class="breadcrumb-item breadcrumb-active">
                <span aria-current="page">Events</span>
            </li>
        </ol>
    </nav>

</body>
</html>
