{{!-- Laylo-Style Dashboard --}}

<div class="laylo-dashboard">
    <!-- Header Section -->
    <div class="dashboard-header">
        <h1 class="greeting">Good evening, BOUNCE2BOUNCE</h1>

        <!-- Shortcuts -->
        <div class="shortcuts">
            <span class="shortcuts-label">Shortcuts</span>
            <a href="/dashboard/messages" class="shortcut-btn">
                <span class="shortcut-icon">💬</span>
                Send a message
            </a>
            <a href="/campaigns" class="shortcut-btn">
                <span class="shortcut-icon">📸</span>
                Run an Instagram Campaign
            </a>
            <a href="/dashboard/events/create" class="shortcut-btn">
                <span class="shortcut-icon">🎵</span>
                Create a multievent
            </a>
            <a href="/merch" class="shortcut-btn">
                <span class="shortcut-icon">👕</span>
                Set up a merch Event
            </a>
        </div>
    </div>

    <!-- Email Domain Setup Card -->
    <div class="setup-card">
        <div class="setup-icon">
            <div class="icon-gradient"></div>
        </div>
        <div class="setup-content">
            <h3>Finish setting up your email domain</h3>
            <p>Add DMARC records to ensure better deliverability and build more trust with your fans.</p>
            <a href="/settings/email" class="setup-link">DMARC setup guide</a>
        </div>
    </div>

    <!-- Events Coming Soon Section -->
    <div class="events-soon">
        <h2>Events coming soon</h2>
        <p class="section-subtitle">Announce something new, or see what you have scheduled to launch</p>

        {{#if upcomingEvents.length}}
            <div class="events-grid">
                {{#each upcomingEvents}}
                    <div class="event-card">
                        {{#if image}}
                            <div class="event-image" style="background-image: url('{{image}}')"></div>
                        {{else}}
                            <div class="event-image placeholder"></div>
                        {{/if}}
                        <div class="event-info">
                            <h4>{{title}}</h4>
                            <p class="event-date">{{formatDate scheduledDate "MMM d, yyyy"}}</p>
                        </div>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="empty-events">
                <a href="/dashboard/events/create" class="create-event-btn">
                    <span class="plus-icon">+</span>
                    Create an Event
                </a>
            </div>
        {{/if}}
    </div>

    <!-- Your Events -->
    <div class="events-section">
        <h2>Your Events</h2>
        {{> events/section}}
    </div>
</div>
