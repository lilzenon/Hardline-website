                            <div>
                                <h4 class="text-sm font-semibold text-gray-900 truncate" id="whatsapp-preview-title">Event Title</h4>
                                <p class="text-xs text-gray-600 mt-1 line-clamp-2" id="whatsapp-preview-description">Event description</p>
                                <p class="text-xs text-gray-500 mt-1 truncate" id="whatsapp-preview-url">{{baseUrl}}/event/{{event.slug}}</p>
                            </div>
