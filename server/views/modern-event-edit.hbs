<!-- Modern Drop Edit Page -->
<div class="space-y-6">
    <!-- Responsive Header with Back Button -->
    <div class="responsive-header bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <!-- Mobile Layout (320px-767px) -->
        <div class="flex flex-col space-y-4 sm:hidden">
            <!-- Top Row: Back Button and Status -->
            <div class="flex items-center justify-between">
                <button type="button" onclick="navigateBack()" class="inline-flex items-center px-4 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200 min-h-[44px] min-w-[44px]">
                    <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back
                </button>

                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border {{#if event.is_active}}bg-emerald-50 border-emerald-200 text-emerald-700{{else}}bg-slate-50 border-slate-200 text-slate-600{{/if}} transition-colors duration-200">
                    <div class="w-2 h-2 rounded-full {{#if event.is_active}}bg-emerald-500{{else}}bg-slate-400{{/if}} animate-pulse"></div>
                    <span class="text-sm font-medium">
                        {{#if event.is_active}}Active{{else}}Inactive{{/if}}
                    </span>
                </div>
            </div>

            <!-- Title Row -->
            <div>
                <h1 class="text-xl font-bold text-gray-900 leading-tight">Edit {{event.title}}</h1>
            </div>

            <!-- Action Button -->
            <div>
                <a href="/event/{{event.slug}}" target="_blank" class="inline-flex items-center justify-center w-full px-4 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200 min-h-[44px]">
                    <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    View Live
                </a>
            </div>
        </div>

        <!-- Tablet Layout (768px-1023px) -->
        <div class="hidden sm:flex lg:hidden items-center justify-between">
            <div class="flex items-center space-x-4">
                <button type="button" onclick="navigateBack()" class="inline-flex items-center px-4 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200 min-h-[44px]">
                    <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back
                </button>
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Edit {{event.title}}</h1>
                </div>
            </div>

            <div class="flex items-center space-x-3">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg border {{#if event.is_active}}bg-emerald-50 border-emerald-200 text-emerald-700{{else}}bg-slate-50 border-slate-200 text-slate-600{{/if}} transition-colors duration-200">
                    <div class="w-2 h-2 rounded-full {{#if event.is_active}}bg-emerald-500{{else}}bg-slate-400{{/if}} animate-pulse"></div>
                    <span class="text-sm font-medium">
                        {{#if event.is_active}}Active{{else}}Inactive{{/if}}
                    </span>
                </div>

                <a href="/event/{{event.slug}}" target="_blank" class="inline-flex items-center px-4 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200 min-h-[44px]">
                    <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    View Live
                </a>
            </div>
        </div>

        <!-- Desktop Layout (1024px+) -->
        <div class="hidden lg:flex items-center justify-between">
            <div class="flex items-center space-x-6">
                <button type="button" onclick="navigateBack()" class="inline-flex items-center px-4 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200">
                    <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back
                </button>
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">Edit {{event.title}}</h1>
                </div>
            </div>

            <div class="flex items-center space-x-4">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border {{#if event.is_active}}bg-emerald-50 border-emerald-200 text-emerald-700{{else}}bg-slate-50 border-slate-200 text-slate-600{{/if}} transition-colors duration-200">
                    <div class="w-2.5 h-2.5 rounded-full {{#if event.is_active}}bg-emerald-500{{else}}bg-slate-400{{/if}} animate-pulse"></div>
                    <span class="text-sm font-semibold">
                        {{#if event.is_active}}Active{{else}}Inactive{{/if}}
                    </span>
                </div>

                <a href="/event/{{event.slug}}" target="_blank" class="inline-flex items-center px-4 py-2.5 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200">
                    <svg class="-ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    View Live
                </a>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 xl:gap-6">
        <!-- Form Section (2/3 width on desktop) -->
        <div class="xl:col-span-2">
            <!-- Tab Navigation -->
            <div class="bg-white shadow rounded-lg overflow-hidden">
                <div class="border-b border-gray-200">
                    <nav class="-mb-px flex space-x-8 px-6" aria-label="Tabs">
                        <button type="button" class="tab-btn border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm active" data-tab="page">
                            <div class="flex items-center">
                                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Page
                            </div>
                        </button>

                        <button type="button" class="tab-btn border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" data-tab="messaging">
                            <div class="flex items-center">
                                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                </svg>
                                Messaging
                            </div>
                        </button>

                        <button type="button" class="tab-btn border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" data-tab="advanced">
                            <div class="flex items-center">
                                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                Advanced
                            </div>
                        </button>

                        <button type="button" class="tab-btn border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" data-tab="sharing">
                            <div class="flex items-center">
                                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z" />
                                </svg>
                                Sharing
                            </div>
                        </button>

                        <button type="button" class="tab-btn border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" data-tab="analytics">
                            <div class="flex items-center">
                                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2-2V7a2 2 0 012-2h2a2 2 0 002 2v2a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 00-2 2h-2a2 2 0 00-2 2v6a2 2 0 01-2 2H9z" />
                                </svg>
                                Analytics
                            </div>
                        </button>
                    </nav>
                </div>

                <!-- Form Content -->
                <form id="drop-edit-form" class="event-form">
                    <!-- PAGE TAB CONTENT -->
                    <div class="tab-content active" data-tab-content="page">
                        <div class="home-settings-form">
                            <div class="home-settings-grid">
                                <!-- Basic Information Section -->
                                <div class="form-section">
                                    <h4>Basic Information</h4>

                                    <div class="form-group">
                                        <label for="edit-title">Title *</label>
                                        <input type="text" id="edit-title" name="title" required maxlength="255" value="{{event.title}}" placeholder="Enter event title" class="form-input">
                                        {{#if errors.title}}<p class="error">{{errors.title}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-subtitle">Subtitle</label>
                                        <input type="text" id="edit-subtitle" name="subtitle" maxlength="500" value="{{event.subtitle}}" placeholder="Optional subtitle text (appears below main title)" class="form-input">
                                        <small class="form-help">Appears directly underneath the main title with smaller, lighter styling</small>
                                        {{#if errors.subtitle}}<p class="error">{{errors.subtitle}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-description">Description</label>
                                        <textarea id="edit-description" name="description" rows="4" placeholder="Describe what this event is about" class="form-input">{{event.description}}</textarea>
                                        {{#if errors.description}}<p class="error">{{errors.description}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-slug">URL Slug</label>
                                        <div class="slug-input-wrapper">
                                            <span class="slug-prefix">{{domain}}/event/</span>
                                            <input type="text" id="edit-slug" name="slug" value="{{event.slug}}" placeholder="my-drop" class="form-input">
                                        </div>
                                        <small class="form-help">This will be your event's public URL</small>
                                        {{#if errors.slug}}<p class="error">{{errors.slug}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-button-text">Button Text</label>
                                        <input type="text" id="edit-button-text" name="button_text" maxlength="50" value="{{event.button_text}}" placeholder="Get Notified" class="form-input">
                                        {{#if errors.button_text}}<p class="error">{{errors.button_text}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-artist-name">Artist Name</label>
                                        <input type="text" id="edit-artist-name" name="artist_name" maxlength="100" value="{{event.artist_name}}" placeholder="Performing artist or creator name" class="form-input">
                                        <small class="form-help">The name of the performing artist or event creator</small>
                                        {{#if errors.artist_name}}<p class="error">{{errors.artist_name}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-event-date">Event Date & Time</label>
                                        <input type="datetime-local" id="edit-event-date" name="event_date" value="{{#if event.event_date}}{{formatDateForInput event.event_date}}{{/if}}" class="form-input">
                                        <small class="form-help">When the event or drop will occur</small>
                                        {{#if errors.event_date}}<p class="error">{{errors.event_date}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-event-address">Event Address</label>
                                        <div class="address-input-container">
                                            <input type="text" id="edit-event-address" name="event_address" maxlength="500" value="{{event.event_address}}" placeholder="Start typing venue address or location..." class="form-input address-autocomplete-input">
                                        </div>
                                        <small class="form-help">Physical location or venue address for the event. Start typing for intelligent suggestions.</small>
                                        {{#if errors.event_address}}<p class="error">{{errors.event_address}}</p>{{/if}}

                                        <!-- Hidden fields for enhanced address data -->
                                        <input type="hidden" id="address-latitude" name="address_latitude" value="{{event.address_latitude}}">
                                        <input type="hidden" id="address-longitude" name="address_longitude" value="{{event.address_longitude}}">
                                        <input type="hidden" id="address-formatted" name="address_formatted" value="{{event.address_formatted}}">
                                        <input type="hidden" id="address-components" name="address_components" value="{{json event.address_components}}">
                                        <input type="hidden" id="address-data" name="address_data" value="{{json event.address_data}}">
                                        <input type="hidden" id="address-validated" name="address_validated" value="{{event.address_validated}}">
                                    </div>
                                </div>

                                <!-- Visual Design Section -->
                                <div class="form-section">
                                    <h4>Visual Design</h4>

                                    <div class="form-group">
                                        <label for="edit-cover-image">Cover Image URL</label>
                                        <input type="url" id="edit-cover-image" name="cover_image" value="{{event.cover_image}}" placeholder="https://example.com/image.jpg" class="form-input">
                                        <small class="form-help">Optional: Add a cover image for your event</small>
                                        {{#if errors.cover_image}}<p class="error">{{errors.cover_image}}</p>{{/if}}
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-background-type">Background Type</label>
                                        <select id="edit-background-type" name="background_type" class="form-input">
                                            <option value="gradient" {{#if (eq event.background_type "gradient")}}selected{{/if}}>Gradient</option>
                                            <option value="solid" {{#if (eq event.background_type "solid")}}selected{{/if}}>Solid Color</option>
                                        </select>
                                    </div>

                                    <div class="form-group" id="background-color-group">
                                        <label for="edit-background-color">Background Color</label>
                                        <input type="color" id="edit-background-color" name="background_color" value="{{event.background_color}}" class="form-input file-input">
                                    </div>

                                    <!-- Advanced Gradient Designer -->
                                    <div id="gradient-editor" class="form-group" style="display: none;">
                                        <label>Advanced Gradient Designer</label>

                                        <!-- Gradient Type Selection -->
                                        <div class="gradient-controls-section">
                                            <h4 class="gradient-section-title">Gradient Type</h4>
                                            <div class="gradient-type-controls">
                                                <button type="button" id="gradient-linear" class="gradient-type-btn active" data-type="linear">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                                    </svg>
                                                    Linear
                                                </button>
                                                <button type="button" id="gradient-radial" class="gradient-type-btn" data-type="radial">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                                                    </svg>
                                                    Radial
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Gradient Direction (for linear gradients) -->
                                        <div class="gradient-controls-section" id="gradient-direction-section">
                                            <h4 class="gradient-section-title">Direction</h4>
                                            <div class="gradient-direction-info">
                                                <span class="direction-label">Select gradient direction:</span>
                                            </div>
                                            <div class="gradient-direction-controls">
                                                <!-- Up (180deg) - First color at top -->
                                                <button type="button" class="gradient-direction-btn" data-angle="180" title="Up">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                                                    </svg>
                                                </button>
                                                <!-- Up-Right (225deg) - First color at top-right -->
                                                <button type="button" class="gradient-direction-btn" data-angle="225" title="Up-Right">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                                                    </svg>
                                                </button>
                                                <!-- Right (270deg) - First color at right -->
                                                <button type="button" class="gradient-direction-btn" data-angle="270" title="Right">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                                    </svg>
                                                </button>
                                                <!-- Down-Right (315deg) - First color at bottom-right -->
                                                <button type="button" class="gradient-direction-btn" data-angle="315" title="Down-Right">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7l10 10M17 17H7M17 17V7" />
                                                    </svg>
                                                </button>
                                                <!-- Down (0deg) - First color at bottom -->
                                                <button type="button" class="gradient-direction-btn" data-angle="0" title="Down">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                                    </svg>
                                                </button>
                                                <!-- Down-Left (45deg) - First color at bottom-left -->
                                                <button type="button" class="gradient-direction-btn" data-angle="45" title="Down-Left">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17L7 7M7 7h10M7 7v10" />
                                                    </svg>
                                                </button>
                                                <!-- Left (90deg) - First color at left -->
                                                <button type="button" class="gradient-direction-btn active" data-angle="90" title="Left">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                                                    </svg>
                                                </button>
                                                <!-- Up-Left (135deg) - First color at top-left -->
                                                <button type="button" class="gradient-direction-btn" data-angle="135" title="Up-Left">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 7L7 17M7 17V7M7 17h10" />
                                                    </svg>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Color Stops -->
                                        <div class="gradient-controls-section">
                                            <h4 class="gradient-section-title">Color Stops</h4>
                                            <div id="color-stops-container" class="color-stops-container">
                                                <!-- Color stops will be dynamically generated -->
                                            </div>
                                            <div class="color-stops-actions">
                                                <button type="button" onclick="addColorStop()" class="btn-small btn-secondary">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                                    </svg>
                                                    Add Stop
                                                </button>
                                                <button type="button" onclick="removeColorStop()" class="btn-small btn-secondary">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                                    </svg>
                                                    Remove Stop
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Gradient Preview -->
                                        <div class="gradient-controls-section">
                                            <h4 class="gradient-section-title">Preview</h4>
                                            <div id="gradient-preview" class="gradient-preview"></div>
