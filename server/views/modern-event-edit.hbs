// Logging utility with levels
const LOG_LEVELS = {
    ERROR: 0,
    WARN: 1,
    INFO: 2,
    DEBUG: 3
};

const CURRENT_LOG_LEVEL = LOG_LEVELS.INFO; // Change to DEBUG for verbose logging

function log(level, prefix, message, ...args) {
    if (level <= CURRENT_LOG_LEVEL) {
        const prefixes = {
            [LOG_LEVELS.ERROR]: '❌',
            [LOG_LEVELS.WARN]: '⚠️',
            [LOG_LEVELS.INFO]: '✅',
            [LOG_LEVELS.DEBUG]: '🔍'
        };
        console.log(`${prefixes[level]} ${prefix}`, message, ...args);
    }
}

document.addEventListener('DOMContentLoaded', function() {
