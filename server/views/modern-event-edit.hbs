// Load QR code data with enhanced loading states
async function loadQRCodeData(eventId) {
    const qrDisplay = document.getElementById('qr-code-display');
    const urlDisplayOld = document.getElementById('qr-url-display'); // Legacy element
    const urlDisplayMain = document.getElementById('qr-url-display-main'); // New main element
    const loadingState = document.getElementById('qr-loading-state');

    try {
        console.log('🔍 Loading QR code data for event:', eventId);

        // Show enhanced loading state
        if (loadingState) {
            loadingState.innerHTML = `
                <div class="animate-spin w-8 h-8 border-3 border-blue-500 border-t-transparent rounded-full mx-auto mb-4"></div>
                <p class="text-sm font-medium">Generating QR Code...</p>
            `;
        }

        const response = await fetch(`/api/events/${eventId}/qr-code/data`);
        const result = await response.json();

        if (result.success) {
            const data = result.data;
            console.log('✅ QR code data loaded:', data);

            // Update QR code display with smooth transition
            if (data.qr_code_enabled) {
                await displayQRCode(data.qr_code_url);

                // Update all URL displays
                if (urlDisplayOld) urlDisplayOld.textContent = data.qr_code_url;
                if (urlDisplayMain) urlDisplayMain.textContent = data.qr_code_url;

                // Add success animation
                qrDisplay.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    qrDisplay.style.transform = 'scale(1)';
                }, 100);

                // Update generation time
                const timeElement = document.getElementById('qr-generation-time');
                if (timeElement) {
                    timeElement.textContent = new Date().toLocaleTimeString();
                }

                console.log('✅ QR code display updated successfully');
            } else {
                console.warn('⚠️ QR code is disabled for this event');
                qrDisplay.innerHTML = `
                    <div class="text-gray-400">
                        <svg class="w-12 h-12 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728L18.364 5.636M5.636 18.364l12.728-12.728" />
                        </svg>
                        <p class="text-sm font-medium">QR Code Disabled</p>
                    </div>
                `;
            }

            // Store download URLs for later use
            window.qrDownloadUrls = data.download_urls;
        } else {
            throw new Error(result.message || 'Failed to load QR code data');
        }
    } catch (error) {
        console.error('🚨 Failed to load QR code data:', error);

        // Show enhanced error state
        qrDisplay.innerHTML = `
            <div class="text-red-400">
                <svg class="w-12 h-12 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <p class="text-sm font-medium">Failed to load QR Code</p>
                <p class="text-xs text-red-300 mt-1">Please try refreshing the page</p>
            </div>
        `;

        // Update URL displays with error message
        if (urlDisplayOld) urlDisplayOld.textContent = 'Error loading URL';
        if (urlDisplayMain) urlDisplayMain.textContent = 'Error loading URL';

        // Show error toast
        showToast('❌ Failed to load QR code', 'error', 5000);
    }
}

