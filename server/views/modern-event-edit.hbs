        }
    }, 2000);

    // Add gradient debug function to window for manual testing
    // Debug function removed for cleaner console output

    // Initialize enhanced analytics system
    initializeEnhancedAnalytics();

    // Initialize QR code management
    initializeQRCodeManagement();

    log(LOG_LEVELS.INFO, '✅', 'Drop edit system initialized with enhanced analytics and QR management');
});

// Address Autocomplete Initialization Function
function initializeAddressAutocomplete() {
    console.log('🏠 Initializing address autocomplete system...');

    const addressInput = document.getElementById('edit-event-address');
    if (!addressInput) {
        console.warn('⚠️ Address input field not found');
        return;
    }

    // Check if AddressAutocomplete class is available
    if (typeof AddressAutocomplete === 'undefined') {
        console.error('❌ AddressAutocomplete class not found. Make sure address-autocomplete.js is loaded.');
        return;
    }

    // Initialize the autocomplete
    const autocomplete = new AddressAutocomplete(addressInput, {
        placeholder: 'Start typing venue address or location...',
        enableValidation: true,
        enableCoordinates: true,
        minLength: 3,
        debounceMs: 300,
        maxResults: 5
    });

    // Handle address selection
    addressInput.addEventListener('addressSelected', function(event) {
        const { formatted, coordinates, data, components } = event.detail;

        console.log('🏠 Address selected:', {
            formatted,
            coordinates,
            components
        });

        // Update hidden fields with enhanced address data
        const latitudeField = document.getElementById('address-latitude');
        const longitudeField = document.getElementById('address-longitude');
        const formattedField = document.getElementById('address-formatted');
        const componentsField = document.getElementById('address-components');
        const dataField = document.getElementById('address-data');
        const validatedField = document.getElementById('address-validated');

        if (latitudeField && coordinates) {
            latitudeField.value = coordinates.latitude;
        }
        if (longitudeField && coordinates) {
            longitudeField.value = coordinates.longitude;
        }
        if (formattedField) {
            formattedField.value = formatted;
        }
        if (componentsField && components) {
            componentsField.value = JSON.stringify(components);
        }
        if (dataField && data) {
            dataField.value = JSON.stringify(data);
        }
        if (validatedField) {
            validatedField.value = 'true';
        }

        console.log('✅ Address data updated in hidden fields');

        // Trigger preview update if available
        if (typeof updatePreviewContent === 'function') {
            updatePreviewContent();
        }
    });

    // Store autocomplete instance for potential cleanup
    window.addressAutocomplete = autocomplete;

    console.log('✅ Address autocomplete system initialized successfully');
}

