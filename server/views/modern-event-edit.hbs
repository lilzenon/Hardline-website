    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
}

/* QR Code Display Enhancements */
#qr-code-display {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

#qr-code-display:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

#qr-code-display img {
    transition: all 0.3s ease;
    border-radius: 12px;
}

/* QR Overlay Actions */
#qr-overlay-actions {
    border-radius: 16px;
    transition: all 0.3s ease;
}

/* Download Menu Styles */
#download-menu {
    animation: slideDown 0.2s ease-out;
    transform-origin: top;
}

#download-menu.hidden {
    animation: slideUp 0.2s ease-in;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-10px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes slideUp {
    from {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
    to {
        opacity: 0;
        transform: translateY(-10px) scale(0.95);
    }
}

/* Enhanced Glass Button Styles */
.glass-button {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.glass-button:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.15);
    transform: translateY(-1px);
}

.glass-button:active {
    transform: translateY(0);
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.1);
}

/* QR Stats Cards */
.qr-stat-card {
    transition: all 0.3s ease;
}

.qr-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
}

/* Quick Share Buttons */
.quick-share-btn {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.quick-share-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
}

.quick-share-btn:active {
    transform: translateY(0);
}

/* Loading Animation Enhancements */
.animate-spin {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    from {
        transform: rotate(0deg);
    }
    to {
        transform: rotate(360deg);
    }
}

/* Border Animation for Loading */
.border-3 {
    border-width: 3px;
}

/* QR Preview Modal Enhancements */
#qr-preview-modal {
    backdrop-filter: blur(8px);
    animation: fadeIn 0.3s ease-out;
}

#qr-preview-modal.hidden {
    animation: fadeOut 0.3s ease-in;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: scale(0.9);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

@keyframes fadeOut {
    from {
        opacity: 1;
        transform: scale(1);
    }
    to {
        opacity: 0;
        transform: scale(0.9);
    }
}

/* Responsive Design Enhancements */
@media (max-width: 768px) {
    #qr-code-display {
        width: 12rem;
        height: 12rem;
    }

    .glass-card {
        padding: 1.5rem;
    }

    .quick-share-btn {
        font-size: 0.875rem;
        padding: 0.75rem 1rem;
    }
}

@media (max-width: 640px) {
    #qr-code-display {
        width: 10rem;
        height: 10rem;
    }

    .glass-card {
        padding: 1rem;
    }
}

/* Accessibility Enhancements */
@media (prefers-reduced-motion: reduce) {
    * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}

/* High Contrast Mode Support */
@media (prefers-contrast: high) {
    .glass-card {
        background: white;
        border: 2px solid black;
    }

    .glass-button {
        background: white;
        border: 2px solid black;
        color: black;
    }
}

/* Print Styles for QR Code */
@media print {
    #qr-code-display {
        background: white !important;
        border: 2px solid black !important;
        box-shadow: none !important;
    }

    .glass-card {
        background: white !important;
        border: 1px solid black !important;
        box-shadow: none !important;
    }

    .quick-share-btn,
    .glass-button {
        display: none !important;
    }
}

/* Dashboard-Style Analytics */
.time-period-btn {
    color: #6b7280;
    background: transparent;
    border: none;
    cursor: pointer;
}

.time-period-btn.active {
    color: #1f2937;
    background: white;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
}

.time-period-btn:hover:not(.active) {
    color: #374151;
    background: rgba(255, 255, 255, 0.5);
}

.loading-skeleton {
    background: linear-gradient(90deg, #f3f4f6 25%, #e5e7eb 50%, #f3f4f6 75%);
    background-size: 200% 100%;
    animation: loading-shimmer 1.5s infinite;
    border-radius: 4px;
    display: inline-block;
    width: 60px;
    height: 1em;
}

@keyframes loading-shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
}

/* Geographic toggle styling */
.toggle-btn:hover:not(.active) {
    color: #374151;
    background: rgba(255, 255, 255, 0.5);
}

/* Legend styling for charts */
.legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.legend-color {
    width: 12px;
    height: 12px;
    border-radius: 50%;
}

.legend-label {
    font-size: 0.875rem;
    color: #6b7280;
    font-weight: 500;
}

/* Responsive Design */
@media (max-width: 640px) {
    .time-period-btn {
        padding: 8px 12px;
        font-size: 0.875rem;
    }
}

@media (max-width: 480px) {
    .time-period-btn {
        padding: 6px 10px;
        font-size: 0.75rem;
    }
}

/* Enhanced Keyword Management Styles */
.glassmorphism-card {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transition: all 0.2s ease;
}

.glassmorphism-card:hover {
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    transform: translateY(-1px);
}

.keyword-item {
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.keyword-item:hover {
    transform: translateY(-1px);
}

/* Compact usage counter badges */
.keyword-item .bg-blue-100 {
    background-color: #dbeafe;
    color: #1e40af;
}

.keyword-item .bg-green-100 {
    background-color: #dcfce7;
    color: #166534;
}

.keyword-item .bg-purple-100 {
    background-color: #f3e8ff;
    color: #7c3aed;
}

/* Touch-friendly button sizing */
.keyword-item button {
    min-height: 44px;
    min-width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Mobile keyword management adjustments */
@media (max-width: 640px) {
    .keyword-item {
        padding: 12px;
    }

    .keyword-item .flex {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }

    .keyword-item .flex:last-child {
        flex-direction: row;
        align-items: center;
        align-self: flex-end;
    }
}
</style>

<!-- Instagram Keyword Test Modal - Fixed z-index and overlay issues -->
<div id="instagram-test-modal" class="fixed inset-0 z-[9999] hidden overflow-y-auto" style="z-index: 9999;">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
        <!-- Backdrop with proper z-index -->
        <div id="modal-backdrop" class="fixed inset-0 bg-black bg-opacity-50 transition-opacity" aria-hidden="true" style="z-index: 9998;"></div>

        <!-- Spacer element for centering -->
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <!-- Modal content with highest z-index -->
        <div class="relative inline-block align-bottom bg-white rounded-xl px-6 pt-6 pb-6 text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full" style="z-index: 10000;">
            <!-- Header -->
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center">
                    <div class="flex items-center justify-center h-10 w-10 rounded-full bg-gradient-to-r from-blue-500 to-purple-600">
                        <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-lg font-semibold text-gray-900">Test Instagram Keywords</h3>
                        <p class="text-sm text-gray-500">Simulate comments without Facebook approval</p>
                    </div>
                </div>
                <button type="button" id="close-test-modal" class="rounded-lg p-2 text-gray-600 bg-gray-100 hover:text-gray-700 hover:bg-gray-200 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-200">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Content -->
            <div class="space-y-6">
                <div>
                    <label for="test-comment-text" class="block text-sm font-medium text-gray-700 mb-2">Simulated Comment</label>
                    <input type="text" id="test-comment-text" placeholder="e.g., I want to TEST this feature!" class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm transition-colors">
                </div>

                <div id="test-results" class="hidden">
                    <div class="bg-gradient-to-r from-gray-50 to-blue-50 rounded-lg p-4 border border-gray-200">
                        <h4 class="text-sm font-semibold text-gray-900 mb-3 flex items-center">
                            <svg class="h-4 w-4 mr-2 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                            </svg>
                            Test Results
                        </h4>
                        <div id="test-results-content"></div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-end space-x-3 mt-8 pt-6 border-t border-gray-200">
                <button type="button" id="close-test-modal-secondary" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                    Cancel
                </button>
                <button type="button" id="run-keyword-test" class="px-6 py-2 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg hover:from-blue-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all shadow-sm">
                    <span id="test-button-text">Run Test</span>
                    <svg id="test-button-spinner" class="hidden animate-spin ml-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>