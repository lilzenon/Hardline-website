// Create QR code
async function createQRCode(formData) {
    try {
        const data = {
            name: formData.get('name'),
            description: formData.get('description'),
            custom_url: formData.get('custom_url')
        };

        const response = await fetch(`/api/events/{{event.id}}/qr-codes`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            credentials: 'same-origin',
            body: JSON.stringify(data)
        });

        if (response.ok) {
            showNotification('QR code created successfully!', 'success');
            loadQRCodes(); // Reload the grid
        } else {
            const error = await response.json();
            throw new Error(error.message || 'Failed to create QR code');
        }
    } catch (error) {
        console.error('Failed to create QR code:', error);
        showNotification(error.message || 'Failed to create QR code', 'error');
    }
}

// Update QR code
async function updateQRCode(qrId, formData) {
    try {
        const data = {
            name: formData.get('name'),
            description: formData.get('description'),
            custom_url: formData.get('custom_url')
        };

        const response = await fetch(`/api/events/{{event.id}}/qr-codes/${qrId}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            credentials: 'same-origin',
            body: JSON.stringify(data)
        });

        if (response.ok) {
            showNotification('QR code updated successfully!', 'success');
            loadQRCodes(); // Reload the grid
        } else {
            const error = await response.json();
            throw new Error(error.message || 'Failed to update QR code');
        }
    } catch (error) {
        console.error('Failed to update QR code:', error);
        showNotification(error.message || 'Failed to update QR code', 'error');
    }
}

// Download QR code
async function downloadQRCode(qrId) {
    try {
        const format = 'png';
        const size = 512;
        const response = await fetch(`/api/events/{{event.id}}/qr-codes/${qrId}/image?format=${format}&size=${size}`, {
            credentials: 'same-origin'
        });

        if (response.ok) {
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `qr-code-${qrId}.${format}`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

            showNotification('QR code downloaded successfully!', 'success');
        } else {
            throw new Error('Failed to download QR code');
        }
    } catch (error) {
        console.error('Failed to download QR code:', error);
        showNotification('Failed to download QR code', 'error');
    }
}

// Load QR code image into preview container
async function loadQRCodeImage(qrId, identifier) {
    const previewContainer = document.getElementById(`qr-preview-${qrId}`);
    if (!previewContainer) return;

    try {
        // Create image element
        const img = new Image();
        img.className = 'w-full h-full object-contain rounded-lg';
        img.alt = `QR Code ${identifier}`;

        // Set up load handler with enhanced scroll prevention
        img.onload = () => {
            // Store current scroll position to prevent unwanted scrolling
            const currentScrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const currentScrollLeft = window.pageXOffset || document.documentElement.scrollLeft;

            // Use requestAnimationFrame to ensure DOM is stable before manipulation
            requestAnimationFrame(() => {
                previewContainer.innerHTML = '';
                previewContainer.appendChild(img);

                // Restore scroll position if it changed
                requestAnimationFrame(() => {
                    const newScrollTop = window.pageYOffset || document.documentElement.scrollTop;
                    const newScrollLeft = window.pageXOffset || document.documentElement.scrollLeft;

                    if (Math.abs(newScrollTop - currentScrollTop) > 5 || Math.abs(newScrollLeft - currentScrollLeft) > 5) {
                        window.scrollTo({
                            top: currentScrollTop,
                            left: currentScrollLeft,
                            behavior: 'instant'
                        });
                    }
                });
            });
        };

        // Set up error handler
        img.onerror = () => {
            previewContainer.innerHTML = `
                <div class="text-center">
                    <svg class="w-12 h-12 text-red-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
                    </svg>
                    <p class="text-xs text-red-500">Failed to load</p>
                </div>
            `;
        };

        // Load the QR code image
        img.src = `/api/events/{{event.id}}/qr-codes/${qrId}/image?format=png&size=192`;

    } catch (error) {
        console.error('Failed to load QR code image:', error);
        previewContainer.innerHTML = `
            <div class="text-center">
                <svg class="w-12 h-12 text-gray-400 mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M3 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 13a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1v-3zM13 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1V4z"/>
                </svg>
                <p class="text-xs text-gray-500">QR Code</p>
            </div>
        `;
    }
}

// Copy QR code URL with enhanced feedback
async function copyQRCodeURL(url, qrName) {
    try {
        await navigator.clipboard.writeText(url);
        showNotification(`QR code URL copied for "${qrName}"`, 'success');

        // Visual feedback - briefly change button text
        const button = event.target.closest('button');
        if (button) {
            const originalContent = button.innerHTML;
            button.innerHTML = `
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Copied!</span>
            `;
            button.classList.add('bg-emerald-600');

            setTimeout(() => {
                button.innerHTML = originalContent;
                button.classList.remove('bg-emerald-600');
            }, 2000);
        }
    } catch (error) {
        console.error('Failed to copy URL:', error);
        showNotification('Failed to copy URL', 'error');
    }
}

// Share QR code with native sharing or fallback
async function shareQRCode(qrId, qrName) {
    try {
        const qrUrl = `${window.location.origin}/qr/${qrId}`;
        const shareData = {
            title: `QR Code: ${qrName}`,
            text: `Check out this QR code for ${qrName}`,
            url: qrUrl
        };

        // Check if native sharing is available (mobile devices)
        if (navigator.share && navigator.canShare && navigator.canShare(shareData)) {
            await navigator.share(shareData);
            showNotification('QR code shared successfully', 'success');
        } else {
            // Fallback: copy to clipboard and show share options
            await navigator.clipboard.writeText(qrUrl);
            showNotification('QR code URL copied to clipboard', 'success');

            // Could also open a share modal here with social media options
            console.log('Share fallback: URL copied to clipboard');
        }
    } catch (error) {
        console.error('Failed to share QR code:', error);
        showNotification('Failed to share QR code', 'error');
    }
}

// Delete QR code
async function deleteQRCode(qrId) {
    if (!confirm('Are you sure you want to delete this QR code? This action cannot be undone.')) {
        return;
    }

    try {
        const response = await fetch(`/api/events/{{event.id}}/qr-codes/${qrId}`, {
            method: 'DELETE',
            credentials: 'same-origin'
        });

        if (response.ok) {
            showNotification('QR code deleted successfully!', 'success');
            loadQRCodes(); // Reload the grid
        } else {
            throw new Error('Failed to delete QR code');
        }
    } catch (error) {
        console.error('Failed to delete QR code:', error);
        showNotification('Failed to delete QR code', 'error');
    }
}

// Close modal with scroll position restoration
function closeModalWithScrollRestore(element, scrollTop, scrollLeft) {
    const modal = element.closest('.fixed');
    if (modal) {
        // First remove the modal
        modal.remove();

        // Then restore body styles and scroll position
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.left = '';
        document.body.style.width = '';
        document.body.style.overflow = '';

        // Restore scroll position after a brief delay to ensure DOM is updated
        requestAnimationFrame(() => {
            window.scrollTo({
                top: scrollTop || 0,
                left: scrollLeft || 0,
                behavior: 'instant'
            });
        });
    }
}

