    safeUpdateElement('qr-conversion-rate', `${((qrData.totalScans > 0 ? (data.conversions / qrData.totalScans) * 100 : 0) || 0).toFixed(1)}%`);

    // Update recent QR activity
    const activityContainer = document.getElementById('qr-recent-activity');
    if (activityContainer && qrData.recentActivity) {
        if (qrData.recentActivity.length > 0) {
            activityContainer.innerHTML = qrData.recentActivity.map(activity => `
