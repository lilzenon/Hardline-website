// Update QR code statistics
function updateQRCodeStats(qrCodes) {
    const totalCount = qrCodes.length;
    const activeCount = qrCodes.filter(qr => qr.is_active).length;
    const totalScans = qrCodes.reduce((sum, qr) => sum + (qr.scan_count || 0), 0);
    const bestPerformer = qrCodes.reduce((best, qr) =>
        (qr.scan_count || 0) > (best.scan_count || 0) ? qr : best,
        qrCodes[0] || {}
    );

    safeUpdateElement('total-qr-count', totalCount);
    safeUpdateElement('total-qr-scans', formatNumber(totalScans));
    safeUpdateElement('active-qr-count', activeCount);
    safeUpdateElement('best-qr-name', bestPerformer.name || 'None');
}

