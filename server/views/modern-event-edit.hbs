}

.toggle-slider {
    position: relative;
    display: block;
    width: 48px; /* Increased for better proportions and accessibility */
    height: 28px; /* Increased for better proportions and accessibility */
    background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
