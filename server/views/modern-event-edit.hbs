                    </svg>
                    <span>Click "Add Keyword" to get started</span>
                </div>
            `;
            fragment.appendChild(emptyState);
        } else {
            // Create all keyword elements in memory first
            keywords.forEach((keyword) => {
                const keywordElement = createKeywordElement(keyword, type);
                fragment.appendChild(keywordElement);
