                        <div class="space-y-2">
                            <div class="w-full h-32 bg-gray-200 rounded overflow-hidden">
                                <img id="whatsapp-preview-image" src="/static/images/default-event-preview.jpg" alt="Event preview" class="w-full h-full object-cover">
