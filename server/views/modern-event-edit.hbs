            left: 0,
            behavior: 'instant' // No smooth scrolling on page load
        });
    }

    // Disable any automatic scroll restoration by the browser
    if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
    }

    // Add global escape key handler to close stuck modals
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            // Close any dynamically created modals (QR code modals, etc.)
            const dynamicModals = document.querySelectorAll('.fixed.inset-0');
            dynamicModals.forEach(modal => {
                modal.remove();
            });

            // Close any remaining modal dialogs (should be rare on event edit page)
            const existingModals = document.querySelectorAll('.dialog:not(.hidden), [id*="modal"]:not(.hidden)');
            existingModals.forEach(modal => {
                modal.classList.add('hidden');
                modal.style.display = 'none';
            });

            // Reset body styles in case any modal left them in a bad state
            resetBodyStyles();

            console.log('🔄 Escape pressed - closed any stuck modals and reset body styles');
        }
    });

    // Clean up any residual modal states on page load (should not be needed anymore)
    setTimeout(() => {
