// Modern Analytics Helper Functions
function updateTrendIndicator(elementId, changeValue) {
    const indicator = document.getElementById(elementId);
    if (!indicator) return;

    const isPositive = (changeValue || 0) >= 0;
    const icon = indicator.querySelector('svg');

    if (icon) {
        icon.className = `w-4 h-4 ${isPositive ? 'text-green-500' : 'text-red-500'}`;
        icon.style.transform = isPositive ? 'rotate(0deg)' : 'rotate(180deg)';
    }
}

function getChangeText(changeValue) {
    if (!changeValue) return 'vs. previous period';
    const sign = changeValue >= 0 ? '+' : '';
    return `${sign}${changeValue.toFixed(1)}% vs. previous period`;
}

// Time Period Control Functions
function initializeTimePeriodControls() {
    const buttons = document.querySelectorAll('.time-period-btn');

    buttons.forEach(button => {
        button.addEventListener('click', function() {
            // Remove active class from all buttons
            buttons.forEach(btn => {
                btn.classList.remove('active');
                btn.setAttribute('aria-pressed', 'false');
            });

            // Add active class to clicked button
            this.classList.add('active');
            this.setAttribute('aria-pressed', 'true');

            // Reload analytics with new time period
            loadAnalytics();
        });
    });
}

// D3.js Chart Functions
function renderViewsTrendChart(data, timeRange) {
    const container = document.getElementById('views-trend-chart');
    if (!container || !data.dailyTrend) return;

    // Clear loading state
    container.innerHTML = '';

    // Set dimensions and margins
    const margin = { top: 20, right: 30, bottom: 40, left: 50 };
    const width = container.clientWidth - margin.left - margin.right;
    const height = 320 - margin.top - margin.bottom;

    // Create SVG
    const svg = d3.select(container)
        .append('svg')
        .attr('width', width + margin.left + margin.right)
        .attr('height', height + margin.top + margin.bottom);

    const g = svg.append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

    // Parse data
    const parseTime = d3.timeParse('%Y-%m-%d');
    const chartData = data.dailyTrend.map(d => ({
        date: parseTime(d.date) || new Date(d.date),
        views: d.views || 0
    })).filter(d => d.date);

    // Set scales
    const xScale = d3.scaleTime()
        .domain(d3.extent(chartData, d => d.date))
        .range([0, width]);

    const yScale = d3.scaleLinear()
        .domain([0, d3.max(chartData, d => d.views) || 1])
        .nice()
        .range([height, 0]);

    // Create line generator
    const line = d3.line()
        .x(d => xScale(d.date))
        .y(d => yScale(d.views))
        .curve(d3.curveMonotoneX);

    // Add gradient
    const gradient = svg.append('defs')
        .append('linearGradient')
        .attr('id', 'area-gradient')
        .attr('gradientUnits', 'userSpaceOnUse')
        .attr('x1', 0).attr('y1', height)
        .attr('x2', 0).attr('y2', 0);

    gradient.append('stop')
        .attr('offset', '0%')
        .attr('stop-color', '#3b82f6')
        .attr('stop-opacity', 0.1);

    gradient.append('stop')
        .attr('offset', '100%')
        .attr('stop-color', '#3b82f6')
        .attr('stop-opacity', 0.3);

    // Add area
    const area = d3.area()
        .x(d => xScale(d.date))
        .y0(height)
        .y1(d => yScale(d.views))
        .curve(d3.curveMonotoneX);

    g.append('path')
        .datum(chartData)
        .attr('fill', 'url(#area-gradient)')
        .attr('d', area);

    // Add line
    g.append('path')
        .datum(chartData)
        .attr('fill', 'none')
        .attr('stroke', '#3b82f6')
        .attr('stroke-width', 2)
        .attr('d', line);

    // Add dots
    g.selectAll('.dot')
        .data(chartData)
        .enter().append('circle')
        .attr('class', 'dot')
        .attr('cx', d => xScale(d.date))
        .attr('cy', d => yScale(d.views))
        .attr('r', 4)
        .attr('fill', '#3b82f6')
        .attr('stroke', '#ffffff')
        .attr('stroke-width', 2);

    // Add axes
    const timeFormat = timeRange == 1 ? d3.timeFormat('%H:%M') : d3.timeFormat('%m/%d');

    g.append('g')
        .attr('transform', `translate(0,${height})`)
        .call(d3.axisBottom(xScale).tickFormat(timeFormat))
        .selectAll('text')
        .style('font-size', '12px')
        .style('fill', '#6b7280');

    g.append('g')
        .call(d3.axisLeft(yScale).ticks(5))
        .selectAll('text')
        .style('font-size', '12px')
        .style('fill', '#6b7280');

    // Add tooltip
    const tooltip = d3.select('body').append('div')
        .attr('class', 'chart-tooltip')
        .style('opacity', 0)
        .style('position', 'absolute')
        .style('background', 'rgba(0, 0, 0, 0.8)')
        .style('color', 'white')
        .style('padding', '8px 12px')
        .style('border-radius', '6px')
        .style('font-size', '12px')
        .style('pointer-events', 'none')
        .style('z-index', '1000');

    g.selectAll('.dot')
        .on('mouseover', function(event, d) {
            tooltip.transition().duration(200).style('opacity', 1);
            tooltip.html(`
                <div><strong>${d.views} views</strong></div>
                <div>${d3.timeFormat('%B %d, %Y')(d.date)}</div>
            `)
            .style('left', (event.pageX + 10) + 'px')
            .style('top', (event.pageY - 10) + 'px');
        })
        .on('mouseout', function() {
            tooltip.transition().duration(200).style('opacity', 0);
        });
}

function renderGeographicChart(data) {
    const container = document.getElementById('geographic-chart');
    if (!container) return;

    // Clear loading state
    container.innerHTML = '';

    // Mock geographic data for demonstration
    const geoData = [
        { location: 'New York, NY', count: Math.floor((data.uniqueVisitors || 0) * 0.3), percentage: 30 },
        { location: 'Los Angeles, CA', count: Math.floor((data.uniqueVisitors || 0) * 0.2), percentage: 20 },
        { location: 'Chicago, IL', count: Math.floor((data.uniqueVisitors || 0) * 0.15), percentage: 15 },
        { location: 'Houston, TX', count: Math.floor((data.uniqueVisitors || 0) * 0.12), percentage: 12 },
        { location: 'Philadelphia, PA', count: Math.floor((data.uniqueVisitors || 0) * 0.1), percentage: 10 },
        { location: 'Other', count: Math.floor((data.uniqueVisitors || 0) * 0.13), percentage: 13 }
    ].filter(d => d.count > 0);

    if (geoData.length === 0) {
        container.innerHTML = '<div class="text-center py-6"><p class="text-sm text-gray-500">No geographic data available</p></div>';
        return;
    }

    // Set dimensions
    const margin = { top: 20, right: 20, bottom: 20, left: 120 };
    const width = container.clientWidth - margin.left - margin.right;
    const height = 320 - margin.top - margin.bottom;

    // Create SVG
    const svg = d3.select(container)
        .append('svg')
        .attr('width', width + margin.left + margin.right)
        .attr('height', height + margin.top + margin.bottom);

    const g = svg.append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

    // Optimized scales with bounds checking and performance improvements
    const maxValue = d3.max(geoData, d => d.count) || 1;
    const xScale = d3.scaleLinear()
        .domain([0, maxValue])
        .range([0, Math.max(width, 1)]) // Ensure positive width
        .clamp(true); // Prevent values outside domain

    const yScale = d3.scaleBand()
        .domain(geoData.map(d => d.location))
        .range([0, height])
        .padding(0.2);

    // Optimized color scale with caching
    const colorScale = d3.scaleSequential(d3.interpolateBlues)
        .domain([0, maxValue]);

    // Pre-calculate values for better performance
    const barData = geoData.map(d => ({
        ...d,
        x: 0,
        y: yScale(d.location),
        width: Math.max(xScale(d.count), 0),
        height: Math.max(yScale.bandwidth(), 1),
        fill: colorScale(d.count)
    }));

    // Optimized bar rendering with reduced DOM operations
    const bars = g.selectAll('.bar')
        .data(barData, d => d.location); // Use key function for better updates

    // Remove old bars
    bars.exit().remove();

    // Add new bars
    const newBars = bars.enter().append('rect')
        .attr('class', 'bar')
        .attr('x', d => d.x)
        .attr('y', d => d.y)
        .attr('width', 0) // Start with 0 width for animation
        .attr('height', d => d.height)
        .attr('fill', d => d.fill)
        .attr('rx', 4);

    // Update existing bars and animate
    newBars.merge(bars)
        .transition()
        .duration(600) // Reduced duration for better performance
        .ease(d3.easeQuadOut) // Smoother easing
        .attr('width', d => d.width);

    // Add labels
    g.selectAll('.label')
        .data(geoData)
        .enter().append('text')
        .attr('class', 'label')
        .attr('x', -10)
        .attr('y', d => yScale(d.location) + yScale.bandwidth() / 2)
        .attr('dy', '0.35em')
        .attr('text-anchor', 'end')
        .style('font-size', '12px')
        .style('fill', '#374151')
        .text(d => d.location);

    // Add value labels
    g.selectAll('.value')
        .data(geoData)
        .enter().append('text')
        .attr('class', 'value')
        .attr('x', d => xScale(d.count) + 8)
        .attr('y', d => yScale(d.location) + yScale.bandwidth() / 2)
        .attr('dy', '0.35em')
        .style('font-size', '11px')
        .style('fill', '#6b7280')
        .text(d => `${d.count} (${d.percentage}%)`);
}

function renderTrafficSourcesChart(data) {
    const container = document.getElementById('traffic-sources-chart');
    if (!container) return;

    // Clear loading state
    container.innerHTML = '';

    // Mock traffic sources data
    const trafficData = [
        { source: 'SMS', count: Math.floor((data.totalViews || 0) * 0.35), color: '#3b82f6' },
        { source: 'Direct', count: Math.floor((data.totalViews || 0) * 0.25), color: '#10b981' },
        { source: 'Instagram DM', count: Math.floor((data.totalViews || 0) * 0.2), color: '#f59e0b' },
        { source: 'QR Code', count: data.qrScans || 0, color: '#8b5cf6' },
        { source: 'Email', count: Math.floor((data.totalViews || 0) * 0.1), color: '#ef4444' },
        { source: 'Other', count: Math.floor((data.totalViews || 0) * 0.1), color: '#6b7280' }
    ].filter(d => d.count > 0);

    if (trafficData.length === 0) {
        container.innerHTML = '<div class="text-center py-6"><p class="text-sm text-gray-500">No traffic source data available</p></div>';
        return;
    }

    // Set dimensions
    const width = container.clientWidth;
    const height = 400;
    const radius = Math.min(width, height) / 2 - 40;

    // Create SVG
    const svg = d3.select(container)
        .append('svg')
        .attr('width', width)
        .attr('height', height);

    const g = svg.append('g')
        .attr('transform', `translate(${width / 2},${height / 2})`);

    // Create pie layout
    const pie = d3.pie()
        .value(d => d.count)
        .sort(null);

    const arc = d3.arc()
        .innerRadius(radius * 0.4)
        .outerRadius(radius);

    const outerArc = d3.arc()
        .innerRadius(radius * 1.1)
        .outerRadius(radius * 1.1);

    // Add slices
    const slices = g.selectAll('.slice')
        .data(pie(trafficData))
        .enter().append('g')
        .attr('class', 'slice');

    slices.append('path')
        .attr('d', arc)
        .attr('fill', d => d.data.color)
        .attr('stroke', '#ffffff')
        .attr('stroke-width', 2)
        .style('opacity', 0.9)
        .transition()
        .duration(800)
        .attrTween('d', function(d) {
            const interpolate = d3.interpolate({ startAngle: 0, endAngle: 0 }, d);
            return function(t) {
                return arc(interpolate(t));
            };
        });

    // Add labels
    slices.append('text')
        .attr('transform', d => `translate(${outerArc.centroid(d)})`)
        .attr('dy', '0.35em')
        .style('text-anchor', d => (d.endAngle + d.startAngle) / 2 > Math.PI ? 'end' : 'start')
        .style('font-size', '12px')
        .style('fill', '#374151')
        .text(d => `${d.data.source} (${d.data.count})`);

    // Add legend
    const legend = document.getElementById('traffic-legend');
    if (legend) {
        legend.innerHTML = trafficData.map(d => `
            <div class="legend-item">
                <div class="legend-color" style="background-color: ${d.color}"></div>
                <span class="legend-label">${d.source}: ${d.count}</span>
            </div>
        `).join('');
    }
}

