function initializeTicketPurchasingToggle() {
    const poshEmbedToggle = document.getElementById('edit-posh-embed-enabled');
    const poshEmbedUrlGroup = document.getElementById('posh-embed-url-group');
    const externalTicketUrlGroup = document.getElementById('external-ticket-url-group');
    const poshEmbedUrlInput = document.getElementById('edit-posh-embed-url');
    const externalTicketUrlInput = document.getElementById('edit-external-ticket-url');

    if (!poshEmbedToggle || !poshEmbedUrlGroup || !externalTicketUrlGroup) {
        console.warn('⚠️ Ticket purchasing toggle elements not found');
        return;
    }

    // Function to update visibility based on toggle state
    function updateTicketUrlVisibility() {
        const isPoshEmbedEnabled = poshEmbedToggle.checked;

        if (isPoshEmbedEnabled) {
            poshEmbedUrlGroup.style.display = 'block';
            externalTicketUrlGroup.style.display = 'none';

            // Enable Posh embed URL input and disable external URL input
            if (poshEmbedUrlInput) poshEmbedUrlInput.disabled = false;
            if (externalTicketUrlInput) {
                externalTicketUrlInput.disabled = true;
                externalTicketUrlInput.value = ''; // Clear the value when disabled
            }
        } else {
            poshEmbedUrlGroup.style.display = 'none';
            externalTicketUrlGroup.style.display = 'block';

            // Enable external URL input and disable Posh embed URL input
            if (externalTicketUrlInput) externalTicketUrlInput.disabled = false;
            if (poshEmbedUrlInput) {
                poshEmbedUrlInput.disabled = true;
                // Don't clear Posh URL value in case user toggles back
            }
        }

        console.log('🎫 Ticket purchasing mode updated:', isPoshEmbedEnabled ? 'Posh Embed' : 'External URL');
    }

    // Set initial state
    updateTicketUrlVisibility();

    // Add event listener for toggle changes
    poshEmbedToggle.addEventListener('change', updateTicketUrlVisibility);

    console.log('✅ Ticket purchasing toggle initialized');
}

