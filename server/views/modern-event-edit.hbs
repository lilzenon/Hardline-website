// Global function to reset body styles (useful for fixing stuck modals)
function resetBodyStyles() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.width = '';
    document.body.style.overflow = '';
    document.body.classList.remove('modal-open');
    console.log('🔄 Body styles reset');
}

// Comprehensive function to close all modals and reset everything
function closeAllModalsAndReset() {
    // Close dynamically created modals
    document.querySelectorAll('.fixed.inset-0').forEach(modal => modal.remove());

    // Close existing modal system modals
    document.querySelectorAll('.dialog:not(.hidden), [id*="dialog"]:not(.hidden), [id*="modal"]:not(.hidden)').forEach(modal => {
        modal.classList.add('hidden');
    });

    // Reset body styles
    resetBodyStyles();

    // Reset any form states
    document.querySelectorAll('form').forEach(form => {
        if (form.id && form.id.includes('create')) {
            form.reset();
        }
    });

    console.log('🔄 All modals closed and styles reset');
}

// Emergency function to close any stuck modals (should not be needed on event edit page)
function emergencyCloseAllModals() {
    // Close any dynamically created modals (QR codes, etc.)
    const dynamicModals = document.querySelectorAll('.fixed.inset-0');
    dynamicModals.forEach(modal => modal.remove());

    // Nuclear reset of body styles
    document.body.style.cssText = '';
    document.body.className = document.body.className.replace(/modal[^\s]*/g, '');

    console.log('🚨 Emergency modal closure completed');
}

