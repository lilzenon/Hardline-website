    // Show add keyword form
    function showAddKeywordForm(type) {
        if (type === 'instagram') {
            instagramAddKeyword.classList.remove('hidden');
            instagramAddButtonContainer.classList.add('hidden');
            instagramKeywordInput.focus();
        } else {
            smsAddKeyword.classList.remove('hidden');
            smsAddButtonContainer.classList.add('hidden');
            smsKeywordInput.focus();
        }
    }

    // Hide add keyword form
    function hideAddKeywordForm(type) {
        if (type === 'instagram') {
            instagramAddKeyword.classList.add('hidden');
            instagramAddButtonContainer.classList.remove('hidden');
            instagramKeywordInput.value = '';
            instagramResponseInput.value = '';
        } else {
            smsAddKeyword.classList.add('hidden');
            smsAddButtonContainer.classList.remove('hidden');
            smsKeywordInput.value = '';
            smsResponseInput.value = '';
        }
    }

    // Add keyword
    async function addKeyword(type) {
        const keywordInput = type === 'instagram' ? instagramKeywordInput : smsKeywordInput;
        const responseInput = type === 'instagram' ? instagramResponseInput : smsResponseInput;
        const addBtn = type === 'instagram' ? instagramAddKeywordBtn : smsAddKeywordBtn;

        const keyword = keywordInput.value.trim();
        const autoResponseMessage = responseInput.value.trim();

        if (!keyword) {
            showNotification('Please enter a keyword', 'error');
            return;
        }

        // Show loading state
        addBtn.disabled = true;
        addBtn.innerHTML = `
            <svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Adding...
        `;

        try {
            const fetchResponse = await fetch('/api/integrations/keywords', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    keyword: keyword,
                    keyword_type: type,
                    event_id: eventId,
                    auto_response_message: autoResponseMessage || null,
                    send_auto_response: !!autoResponseMessage,
                    is_active: true
                })
            });

            const data = await fetchResponse.json();

            if (data.success) {
                showNotification(`${type.charAt(0).toUpperCase() + type.slice(1)} keyword added successfully!`, 'success');
                hideAddKeywordForm(type);
                await loadKeywords(); // Reload keywords
            } else {
                throw new Error(data.error || 'Failed to add keyword');
            }

        } catch (error) {
            console.error('Error adding keyword:', error);
            showNotification('Failed to add keyword: ' + error.message, 'error');
        } finally {
            // Reset button state
            addBtn.disabled = false;
            addBtn.innerHTML = `
                <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
                </svg>
                Add
            `;
        }
    }

    // Edit keyword (inline editing)
    async function editKeyword(keywordId, keyword, type) {
        const keywordElement = document.querySelector(`[data-keyword-id="${keywordId}"]`).closest('.keyword-item');
        const originalContent = keywordElement.innerHTML;

        // Create inline edit form
        keywordElement.innerHTML = `
            <div class="flex items-center space-x-2">
                <input type="text" id="edit-keyword-${keywordId}" value="${keyword.keyword}" class="flex-1 px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 min-h-[44px]">
                <input type="text" id="edit-response-${keywordId}" value="${keyword.auto_response_message || ''}" placeholder="Auto-response" class="flex-1 px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 min-h-[44px]">
                <button type="button" class="save-edit-btn px-3 py-1 bg-green-600 text-white rounded text-sm hover:bg-green-700 min-h-[44px] transition-colors">Save</button>
                <button type="button" class="cancel-edit-btn px-3 py-1 bg-gray-300 text-gray-700 rounded text-sm hover:bg-gray-400 min-h-[44px] transition-colors">Cancel</button>
            </div>
        `;

        // Focus on keyword input
        document.getElementById(`edit-keyword-${keywordId}`).focus();

        // Add event listeners
        keywordElement.querySelector('.save-edit-btn').addEventListener('click', async () => {
            const newKeyword = document.getElementById(`edit-keyword-${keywordId}`).value.trim();
            const newResponse = document.getElementById(`edit-response-${keywordId}`).value.trim();

            if (!newKeyword) {
                showNotification('Keyword cannot be empty', 'error');
                return;
            }

            try {
                const response = await fetch(`/api/integrations/keywords/${keywordId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        keyword: newKeyword,
                        auto_response_message: newResponse,
                        keyword_type: type,
                        event_id: eventId
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showNotification('Keyword updated successfully', 'success');
                    loadKeywords(); // Reload keywords
                } else {
                    showNotification('Failed to update keyword: ' + data.error, 'error');
                    keywordElement.innerHTML = originalContent;
                }
            } catch (error) {
                console.error('Error updating keyword:', error);
                showNotification('Failed to update keyword: ' + error.message, 'error');
                keywordElement.innerHTML = originalContent;
            }
        });

        keywordElement.querySelector('.cancel-edit-btn').addEventListener('click', () => {
            keywordElement.innerHTML = originalContent;
            // Re-add event listeners after restoring content
            const editBtn = keywordElement.querySelector('.edit-keyword-btn');
            const deleteBtn = keywordElement.querySelector('.delete-keyword-btn');
            editBtn.addEventListener('click', () => editKeyword(keyword.id, keyword, type));
            deleteBtn.addEventListener('click', () => deleteKeyword(keyword.id, keyword.keyword, type));
        });
    }

    // Delete keyword
    async function deleteKeyword(keywordId, keywordText, type) {
        if (!confirm(`Are you sure you want to delete the keyword "${keywordText}"? This action cannot be undone.`)) {
            return;
        }

        try {
            const response = await fetch(`/api/integrations/keywords/${keywordId}`, {
                method: 'DELETE'
            });

            const data = await response.json();

            if (data.success) {
                showNotification('Keyword deleted successfully', 'success');
                await loadKeywords(); // Reload keywords
            } else {
                throw new Error(data.error || 'Failed to delete keyword');
            }

        } catch (error) {
            console.error('Error deleting keyword:', error);
            showNotification('Failed to delete keyword: ' + error.message, 'error');
        }
    }

    // Event listeners
    if (instagramShowAddKeyword) {
        instagramShowAddKeyword.addEventListener('click', () => showAddKeywordForm('instagram'));
    }

    if (instagramCancelKeyword) {
        instagramCancelKeyword.addEventListener('click', () => hideAddKeywordForm('instagram'));
    }

    if (instagramAddKeywordBtn) {
        instagramAddKeywordBtn.addEventListener('click', () => addKeyword('instagram'));
    }

    if (smsShowAddKeyword) {
        smsShowAddKeyword.addEventListener('click', () => showAddKeywordForm('sms'));
    }

    if (smsCancelKeyword) {
        smsCancelKeyword.addEventListener('click', () => hideAddKeywordForm('sms'));
    }

    if (smsAddKeywordBtn) {
        smsAddKeywordBtn.addEventListener('click', () => addKeyword('sms'));
    }

    // Test keywords functionality
    const instagramTestKeywords = document.getElementById('instagram-test-keywords');
    if (instagramTestKeywords) {
        instagramTestKeywords.addEventListener('click', showTestModal);
    }

    // Enter key support for adding keywords
    if (instagramKeywordInput) {
        instagramKeywordInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                addKeyword('instagram');
            }
        });
    }

    if (smsKeywordInput) {
        smsKeywordInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                addKeyword('sms');
            }
        });
    }

    // Enhanced test modal functionality with proper z-index handling
    function showTestModal() {
        log('🧪 showTestModal called');
        const modal = document.getElementById('instagram-test-modal');
        log('🧪 Modal element found:', !!modal);

        if (modal) {
            // Ensure modal is above all other elements
            modal.style.zIndex = '9999';
            modal.classList.remove('hidden');

            // Add body scroll lock to prevent background scrolling
            document.body.style.overflow = 'hidden';

            // Focus on input with slight delay for better UX
            setTimeout(() => {
                const input = document.getElementById('test-comment-text');
                if (input) {
                    input.focus();
                    input.select(); // Select any existing text
                }
            }, 100);

            log('🧪 Modal should now be visible');
        } else {
            logError('❌ Test modal not found in DOM');
        }
    }

    function hideTestModal() {
        const modal = document.getElementById('instagram-test-modal');
        const results = document.getElementById('test-results');
        const input = document.getElementById('test-comment-text');

        if (modal) {
            modal.classList.add('hidden');

            // Restore body scroll
            document.body.style.overflow = '';

            // Clear form and results
            if (results) results.classList.add('hidden');
            if (input) input.value = '';

            // Reset test button state
            resetTestButton();
        }
    }

    function resetTestButton() {
        const button = document.getElementById('run-keyword-test');
        const buttonText = document.getElementById('test-button-text');
        const spinner = document.getElementById('test-button-spinner');

        if (button) button.disabled = false;
        if (buttonText) buttonText.textContent = 'Run Test';
        if (spinner) spinner.classList.add('hidden');
    }

    // Enhanced test modal event listeners
    const closeTestModal = document.getElementById('close-test-modal');
    const closeTestModalSecondary = document.getElementById('close-test-modal-secondary');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const runKeywordTest = document.getElementById('run-keyword-test');

    // Multiple ways to close the modal
    if (closeTestModal) {
        closeTestModal.addEventListener('click', hideTestModal);
    }

    if (closeTestModalSecondary) {
        closeTestModalSecondary.addEventListener('click', hideTestModal);
    }

    if (modalBackdrop) {
        modalBackdrop.addEventListener('click', hideTestModal);
    }

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            const modal = document.getElementById('instagram-test-modal');
            if (modal && !modal.classList.contains('hidden')) {
                hideTestModal();
            }
        }
    });

    if (runKeywordTest) {
        runKeywordTest.addEventListener('click', async () => {
            const commentText = document.getElementById('test-comment-text').value.trim();
            if (!commentText) {
                showNotification('Please enter a comment to test', 'error');
                return;
            }

            try {
                // Enhanced loading state
                const buttonText = document.getElementById('test-button-text');
                const spinner = document.getElementById('test-button-spinner');

                runKeywordTest.disabled = true;
                if (buttonText) buttonText.textContent = 'Testing...';
                if (spinner) spinner.classList.remove('hidden');

                const response = await fetch('/api/integrations/test-instagram-webhook', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        comment_text: commentText,
                        event_id: eventId
                    })
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                }

                const data = await response.json();
                displayTestResults(data);

                // Reload keywords to show updated stats (force refresh cache)
                await loadKeywords(true);

                showNotification('Test completed successfully!', 'success');

            } catch (error) {
                logError('Test error:', error);
                showNotification('Test failed: ' + error.message, 'error');
            } finally {
                resetTestButton();
            }
        });
    }

    function displayTestResults(data) {
        const results = document.getElementById('test-results');
        const content = document.getElementById('test-results-content');

        if (data.success && data.matched_keyword) {
            content.innerHTML = `
                <div class="space-y-4">
                    <!-- Success header -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-3">
                            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                                <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <div>
                                <h4 class="text-sm font-semibold text-green-800">Keyword Matched!</h4>
                                <p class="text-xs text-green-600">Test completed successfully</p>
                            </div>
                        </div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            Success
                        </span>
                    </div>

                    <!-- Match details -->
                    <div class="bg-white rounded-lg border border-green-200 p-3 space-y-3">
                        <div class="flex items-start space-x-3">
                            <svg class="w-4 h-4 text-purple-500 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M9 3a1 1 0 012 0v5.5a.5.5 0 001 0V4a1 1 0 112 0v4.5a.5.5 0 001 0V6a1 1 0 112 0v6a6 6 0 01-6 6H9a6 6 0 01-6-6V9a1 1 0 012 0v.5a.5.5 0 001 0V4a1 1 0 012 0v4.5a.5.5 0 001 0V3z" clip-rule="evenodd"/>
                            </svg>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">Matched Keyword</p>
                                <p class="text-sm text-gray-600 mt-1">
                                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-purple-100 text-purple-700">
                                        "${data.matched_keyword}"
                                    </span>
                                </p>
                            </div>
                        </div>

                        ${data.auto_response ? `
                            <div class="flex items-start space-x-3 pt-3 border-t border-gray-100">
                                <svg class="w-4 h-4 text-blue-500 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd"/>
                                </svg>
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-gray-900">Auto-response</p>
                                    <div class="mt-1 p-2 bg-blue-50 rounded-md border border-blue-200">
                                        <p class="text-sm text-blue-800">"${data.auto_response}"</p>
                                    </div>
                                </div>
                            </div>
                        ` : `
                            <div class="flex items-center space-x-2 pt-3 border-t border-gray-100">
                                <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"/>
                                </svg>
                                <p class="text-sm text-gray-500">No auto-response configured for this keyword</p>
                            </div>
                        `}

                        <div class="flex items-center space-x-2 pt-3 border-t border-gray-100">
                            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.293l-3-3a1 1 0 00-1.414 1.414L10.586 9.5 9.293 10.793a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd"/>
                            </svg>
                            <p class="text-xs font-medium text-green-600">Usage statistics updated successfully</p>
                        </div>
                    </div>
                </div>
            `;
        } else {
            content.innerHTML = `
                <div class="space-y-4">
                    <!-- Warning header -->
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-3">
                            <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center">
                                <svg class="w-4 h-4 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            <div>
                                <h4 class="text-sm font-semibold text-yellow-800">No Keywords Matched</h4>
                                <p class="text-xs text-yellow-600">Test completed with no matches</p>
                            </div>
                        </div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                            No Match
                        </span>
                    </div>

                    <!-- Details -->
                    <div class="bg-white rounded-lg border border-yellow-200 p-3 space-y-3">
                        <div class="flex items-start space-x-3">
                            <svg class="w-4 h-4 text-gray-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                            </svg>
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">Result</p>
                                <p class="text-sm text-gray-600 mt-1">${data.message}</p>
                            </div>
                        </div>

                        ${data.available_keywords && data.available_keywords.length > 0 ? `
                            <div class="pt-3 border-t border-gray-100">
                                <p class="text-sm font-medium text-gray-900 mb-2">Available keywords for this event:</p>
                                <div class="flex flex-wrap gap-1">
                                    ${data.available_keywords.map(keyword =>
                                        `<span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-700">${keyword}</span>`
                                    ).join('')}
                                </div>
                            </div>
                        ` : `
                            <div class="pt-3 border-t border-gray-100">
                                <p class="text-sm text-gray-500">No keywords configured for this event yet.</p>
                            </div>
                        `}
                    </div>
                </div>
            `;
        }

        results.classList.remove('hidden');
    }

    // Notification function
    function showNotification(message, type = 'info') {
        // Create notification element
        const notification = document.createElement('div');
        notification.className = `fixed top-4 right-4 z-50 max-w-md w-full bg-white shadow-lg rounded-lg pointer-events-auto ring-1 ring-black ring-opacity-5 overflow-hidden transform transition-all duration-300 translate-x-full`;

        const bgColor = type === 'success' ? 'bg-green-50' : type === 'error' ? 'bg-red-50' : 'bg-blue-50';
        const textColor = type === 'success' ? 'text-green-800' : type === 'error' ? 'text-red-800' : 'text-blue-800';
        const iconColor = type === 'success' ? 'text-green-400' : type === 'error' ? 'text-red-400' : 'text-blue-400';
        const borderColor = type === 'success' ? 'border-green-200' : type === 'error' ? 'border-red-200' : 'border-blue-200';

        notification.innerHTML = `
            <div class="border-l-4 ${borderColor} ${bgColor} p-4">
                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 ${iconColor}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            ${type === 'success' ?
                                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />' :
                                type === 'error' ?
                                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />' :
                                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />'
                            }
                        </svg>
                    </div>
                    <div class="ml-3 w-0 flex-1">
                        <p class="text-sm font-medium ${textColor} leading-relaxed">${message}</p>
                    </div>
                    <div class="ml-4 flex-shrink-0 flex">
                        <button class="bg-gray-100 rounded-md inline-flex text-gray-600 hover:text-gray-700 hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 p-1 border border-gray-200" onclick="this.closest('.fixed').remove()">
                            <span class="sr-only">Close</span>
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        `;

        document.body.appendChild(notification);

        // Animate in
        setTimeout(() => {
            notification.classList.remove('translate-x-full');
        }, 100);

        // Auto-remove after 5 seconds
        setTimeout(() => {
            if (notification.parentNode) {
                notification.classList.add('translate-x-full');
                setTimeout(() => {
                    if (notification.parentNode) {
                        notification.remove();
                    }
                }, 300);
            }
        }, 5000);
    }
});
</script>

