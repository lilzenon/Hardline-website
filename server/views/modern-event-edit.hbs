<!-- Keyword Management JavaScript -->
<script>
// Keyword Management System
document.addEventListener('DOMContentLoaded', function() {
    // Extract event ID from URL path like /dashboard/events/[eventId]/edit
    const pathParts = window.location.pathname.split('/');
    const eventId = pathParts[pathParts.length - 2]; // Get the part before 'edit'

    // Production logging helper
    const isDevelopment = window.location.hostname === 'localhost' || window.location.hostname.includes('dev');
    const log = isDevelopment ? console.log : () => {};
    const logError = console.error; // Always log errors

    log('🔍 Extracted event ID:', eventId, 'from path:', window.location.pathname);

    // Instagram keyword elements
    const instagramKeywordsContainer = document.getElementById('instagram-keywords-container');
    const instagramKeywordsLoading = document.getElementById('instagram-keywords-loading');
    const instagramConnectionStatus = document.getElementById('instagram-connection-status');
    const instagramNotConnected = document.getElementById('instagram-not-connected');
    const instagramAddKeyword = document.getElementById('instagram-add-keyword');
    const instagramAddButtonContainer = document.getElementById('instagram-add-button-container');
    const instagramShowAddKeyword = document.getElementById('instagram-show-add-keyword');
    const instagramCancelKeyword = document.getElementById('instagram-cancel-keyword-btn');
    const instagramAddKeywordBtn = document.getElementById('instagram-add-keyword-btn');
    const instagramKeywordInput = document.getElementById('instagram-keyword-input');
    const instagramResponseInput = document.getElementById('instagram-response-input');

    // SMS keyword elements
    const smsKeywordsContainer = document.getElementById('sms-keywords-container');
    const smsKeywordsLoading = document.getElementById('sms-keywords-loading');
    const smsConnectionStatus = document.getElementById('sms-connection-status');
    const smsNotConfigured = document.getElementById('sms-not-configured');
    const smsAddKeyword = document.getElementById('sms-add-keyword');
    const smsAddButtonContainer = document.getElementById('sms-add-button-container');
    const smsShowAddKeyword = document.getElementById('sms-show-add-keyword');
    const smsCancelKeyword = document.getElementById('sms-cancel-keyword-btn');
    const smsAddKeywordBtn = document.getElementById('sms-add-keyword-btn');
    const smsKeywordInput = document.getElementById('sms-keyword-input');
    const smsResponseInput = document.getElementById('sms-response-input');

    // Initialize keyword management
    initializeKeywordManagement();

    async function initializeKeywordManagement() {
        await checkInstagramConnection();
        await checkSmsConfiguration();
        await loadKeywords();
    }

    // Check Instagram connection status
    async function checkInstagramConnection() {
        try {
            const response = await fetch('/api/integrations/instagram/status');
            const data = await response.json();

            if (data.success && data.connected && data.accounts.length > 0) {
                instagramConnectionStatus.textContent = 'Connected';
                instagramConnectionStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800';
                instagramNotConnected.classList.add('hidden');
                instagramAddButtonContainer.classList.remove('hidden');
            } else {
                instagramConnectionStatus.textContent = 'Not Connected';
                instagramConnectionStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800';
                instagramNotConnected.classList.remove('hidden');
                instagramAddButtonContainer.classList.add('hidden');
            }
        } catch (error) {
            console.error('Error checking Instagram connection:', error);
            instagramConnectionStatus.textContent = 'Error';
            instagramConnectionStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800';
        }
    }

    // Check SMS configuration status
    async function checkSmsConfiguration() {
        try {
            // Check if SMS is configured (you'll need to implement this endpoint)
            const response = await fetch('/api/sms/status');
            const data = await response.json();

            if (data.success && data.configured) {
                smsConnectionStatus.textContent = 'Configured';
                smsConnectionStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800';
                smsNotConfigured.classList.add('hidden');
                smsAddButtonContainer.classList.remove('hidden');
            } else {
                smsConnectionStatus.textContent = 'Not Configured';
                smsConnectionStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800';
                smsNotConfigured.classList.remove('hidden');
                smsAddButtonContainer.classList.add('hidden');
            }
        } catch (error) {
            console.error('Error checking SMS configuration:', error);
            smsConnectionStatus.textContent = 'Not Configured';
            smsConnectionStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800';
            smsNotConfigured.classList.remove('hidden');
            smsAddButtonContainer.classList.add('hidden');
        }
    }

    // Optimized keyword loading with caching and debouncing
    let keywordCache = new Map();
    let loadKeywordsTimeout = null;

    async function loadKeywords(forceRefresh = false) {
        log('🔄 Loading keywords for event:', eventId);

        // Debounce rapid calls
        if (loadKeywordsTimeout) {
            clearTimeout(loadKeywordsTimeout);
        }

        loadKeywordsTimeout = setTimeout(async () => {
            try {
                // Check cache first (unless force refresh)
                const cacheKey = `keywords_${eventId}`;
                if (!forceRefresh && keywordCache.has(cacheKey)) {
                    const cachedData = keywordCache.get(cacheKey);
                    if (Date.now() - cachedData.timestamp < 30000) { // 30 second cache
                        console.log('📦 Using cached keywords');
                        displayKeywords(cachedData.instagram, 'instagram');
                        displayKeywords(cachedData.sms, 'sms');
                        return;
                    }
                }

                // Load both keyword types in parallel for better performance
                const [instagramResponse, smsResponse] = await Promise.all([
                    fetch(`/api/integrations/keywords?event_id=${eventId}&keyword_type=instagram`),
                    fetch(`/api/integrations/keywords?event_id=${eventId}&keyword_type=sms`)
                ]);

                const [instagramData, smsData] = await Promise.all([
                    instagramResponse.json(),
                    smsResponse.json()
                ]);

                console.log('📱 Keywords loaded:', {
                    instagram: instagramData.keywords?.length || 0,
                    sms: smsData.keywords?.length || 0
                });

                const instagramKeywords = instagramData.success ? instagramData.keywords : [];
                const smsKeywords = smsData.success ? smsData.keywords : [];

                // Cache the results
                keywordCache.set(cacheKey, {
                    instagram: instagramKeywords,
                    sms: smsKeywords,
                    timestamp: Date.now()
                });

                // Display keywords
                displayKeywords(instagramKeywords, 'instagram');
                displayKeywords(smsKeywords, 'sms');

            } catch (error) {
                console.error('Error loading keywords:', error);
                // Show empty state for both
                displayKeywords([], 'instagram');
                displayKeywords([], 'sms');
            } finally {
                if (instagramKeywordsLoading) instagramKeywordsLoading.classList.add('hidden');
                if (smsKeywordsLoading) smsKeywordsLoading.classList.add('hidden');
            }
        }, 100); // 100ms debounce
    }

    // Optimized display keywords with reduced DOM manipulations
    function displayKeywords(keywords, type) {
        console.log(`🎯 Displaying ${keywords.length} ${type} keywords`);

        const container = type === 'instagram' ? instagramKeywordsContainer : smsKeywordsContainer;
        const loadingElement = type === 'instagram' ? instagramKeywordsLoading : smsKeywordsLoading;

        if (!container) {
            console.error(`❌ Container not found for ${type} keywords`);
            return;
        }

        // Clear loading state
        if (loadingElement) {
            loadingElement.classList.add('hidden');
        }

        // Use DocumentFragment for efficient DOM updates
        const fragment = document.createDocumentFragment();

        if (keywords.length === 0) {
            const emptyState = document.createElement('div');
            emptyState.className = 'flex flex-col items-center justify-center py-12 px-6 bg-gradient-to-br from-gray-50 to-gray-100/50 rounded-xl border-2 border-dashed border-gray-300/60 hover:border-gray-400/60 transition-colors';

