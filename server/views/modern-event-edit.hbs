// Display recent QR code activity (compact version)
function displayRecentActivity(activities) {
    const container = document.getElementById('qr-recent-activity');

    // Add null check for container
    if (!container) {
        console.warn('⚠️ QR recent activity container not found');
        return;
    }

    if (!activities || activities.length === 0) {
        container.innerHTML = '<div class="text-sm text-gray-500 text-center py-4">No recent activity</div>';
        return;
    }

    const activityHtml = activities.map(activity => {
        const timeAgo = getTimeAgo(new Date(activity.scan_timestamp));
        const deviceIcon = getDeviceIcon(activity.device_type);
        const location = activity.city && activity.country_code ? `${activity.city}, ${activity.country_code}` : 'Unknown';

        return `
            <div class="flex items-center justify-between py-3 px-4 bg-white rounded-lg border border-gray-200 transition-all duration-200 hover:shadow-md hover:border-blue-200">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center">
                        <span class="text-sm">${deviceIcon}</span>
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="text-sm font-medium text-gray-900 truncate">${activity.browser_name || 'Unknown Browser'}</div>
                        <div class="text-xs text-gray-500 truncate">${location}</div>
                    </div>
                </div>
                <div class="text-xs text-gray-400 ml-3 flex-shrink-0">${timeAgo}</div>
            </div>
        `;
    }).join('');

    container.innerHTML = activityHtml;
}

// Get device icon based on device type
function getDeviceIcon(deviceType) {
    switch (deviceType) {
        case 'mobile':
            return '📱';
        case 'tablet':
            return '📱';
        case 'desktop':
            return '💻';
        default:
            return '📱';
    }
}

// Get time ago string
function getTimeAgo(date) {
    const now = new Date();
    const diffMs = now - date;
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins}m ago`;
    if (diffHours < 24) return `${diffHours}h ago`;
    return `${diffDays}d ago`;
}

// Set up QR code event listeners
function setupQRCodeEventListeners(eventId) {
    // QR toggle functionality removed - QR codes are always enabled

    // Copy QR code image to clipboard
    const copyImageBtn = document.getElementById('copy-qr-image');
    if (copyImageBtn) {
        copyImageBtn.addEventListener('click', async function() {
            try {
                // Show loading state
                const originalText = this.innerHTML;
                this.innerHTML = `
                    <svg class="w-5 h-5 mr-2 animate-spin" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Copying...
                `;
                this.disabled = true;

                // Get QR code as SVG
                const response = await fetch(`/api/events/{{event.id}}/qr-code?format=svg`);
                if (!response.ok) throw new Error('Failed to fetch QR code');

                const svgText = await response.text();

                // Convert SVG to canvas and then to blob
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                const img = new Image();

                await new Promise((resolve, reject) => {
                    img.onload = resolve;
                    img.onerror = reject;
                    img.src = 'data:image/svg+xml;base64,' + btoa(svgText);
                });

                // Set canvas size for high quality
                canvas.width = 512;
                canvas.height = 512;

                // Draw white background
                ctx.fillStyle = 'white';
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Draw QR code
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

                // Convert to blob and copy to clipboard
                canvas.toBlob(async (blob) => {
                    try {
                        await navigator.clipboard.write([
                            new ClipboardItem({ 'image/png': blob })
                        ]);

                        // Success feedback
                        this.innerHTML = `
                            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            Copied!
                        `;
                        showToast('QR code image copied to clipboard', 'success');

                        // Reset button after 2 seconds
                        setTimeout(() => {
                            this.innerHTML = originalText;
                            this.disabled = false;
                        }, 2000);

                    } catch (clipboardError) {
                        throw new Error('Clipboard API not supported');
                    }
                }, 'image/png', 0.95);

            } catch (error) {
                console.error('Failed to copy QR code image:', error);

                // Error feedback
                this.innerHTML = `
                    <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Failed
                `;
                showToast('Failed to copy QR code image. Try using the URL instead.', 'error');

                // Reset button after 2 seconds
                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.disabled = false;
                }, 2000);
            }
        });
    }

    // Copy QR URL
    const copyQrBtn = document.getElementById('copy-qr-url');
    if (copyQrBtn) {
        copyQrBtn.addEventListener('click', async function() {
            const urlDisplay = document.getElementById('qr-url-display');
            const url = urlDisplay.textContent;

            if (url) {
                try {
                    await navigator.clipboard.writeText(url);
                    showToast('QR URL copied to clipboard', 'success');
                } catch (error) {
                    console.error('Failed to copy URL:', error);
                    showToast('Failed to copy URL', 'error');
                }
            }
        });
    }

    // Copy event URL
    const copyEventBtn = document.getElementById('copy-event-url');
    if (copyEventBtn) {
        copyEventBtn.addEventListener('click', async function() {
            const eventUrlInput = document.getElementById('event-url');
            const url = eventUrlInput.value;

            try {
                await navigator.clipboard.writeText(url);
                showToast('Event URL copied to clipboard', 'success');
            } catch (error) {
                console.error('Failed to copy URL:', error);
                showToast('Failed to copy URL', 'error');
            }
        });
    }
}

