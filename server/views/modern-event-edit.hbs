        const form = document.getElementById('drop-edit-form');
        if (form) {
            initializeFormSubmission();
        } else if (formInitAttempts < maxFormInitAttempts) {
            console.log(`⏳ Form not ready, retrying in ${formInitAttempts * 100}ms...`);
            setTimeout(tryInitializeFormSubmission, formInitAttempts * 100);
        } else {
            console.error('❌ Failed to initialize form after maximum attempts');
        }
    }

    tryInitializeFormSubmission();

    // Initialize real-time updates
    initializeRealTimeUpdates();

    // Initialize gradient editor with enhanced retry logic
    let gradientInitAttempts = 0;
    const maxGradientInitAttempts = 5;

    function tryInitializeGradientEditor() {
        gradientInitAttempts++;
        console.log(`🎨 Gradient editor initialization attempt ${gradientInitAttempts}/${maxGradientInitAttempts}`);

        const gradientEditor = document.getElementById('gradient-editor');
        const gradientButtons = document.querySelectorAll('.gradient-type-btn');

        if (gradientEditor && gradientButtons.length > 0) {
            log(LOG_LEVELS.DEBUG, '🎨', 'Initializing gradient editor');
            initializeGradientEditor();
        } else if (gradientInitAttempts < maxGradientInitAttempts) {
            console.log(`⏳ Gradient editor not ready, retrying in ${gradientInitAttempts * 100}ms...`);
            setTimeout(tryInitializeGradientEditor, gradientInitAttempts * 100);
        } else {
            console.error('❌ Failed to initialize gradient editor after maximum attempts');
        }
    }

    setTimeout(tryInitializeGradientEditor, 100);

    // Retry gradient data loading if needed - but don't override user changes
    setTimeout(() => {
        if ((!gradientData || !window.gradientDataLoaded) && !window.userHasModifiedGradient) {
            log(LOG_LEVELS.DEBUG, '🎨', 'Retrying gradient data loading (no user modifications)');
            loadExistingGradientData();
            setTimeout(() => setGradientUIFromData(0), 100);
        } else if (window.userHasModifiedGradient) {
            log(LOG_LEVELS.DEBUG, '🎨', 'Skipping data reload - user has modified gradient');
        }
    }, 1000);

    // Final gradient UI sync - but don't override user changes
    setTimeout(() => {
        const backgroundTypeSelect = document.getElementById('edit-background-type');
        if (backgroundTypeSelect?.value === 'gradient') {
            if (gradientData && !window.userHasModifiedGradient) {
                // Only sync UI if user hasn't made changes
                setGradientUIFromData(0);
                updateGradientPreview();
                log(LOG_LEVELS.DEBUG, '🎨', 'Gradient UI synced (no user modifications)');
            } else if (!gradientData) {
                gradientData = { ...defaultGradientData };
