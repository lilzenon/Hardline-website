                    </div>
                    <p class="text-xs text-gray-600 mt-2 text-center">How it appears in WhatsApp chats</p>
                </div>

                <!-- Social Media Preview -->
                <div id="social-preview" class="preview-content hidden bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg p-4">
                    <div class="bg-white rounded-lg p-3 shadow-sm max-w-md">
                        <div class="space-y-3">
                            <div class="w-full h-40 bg-gray-200 rounded overflow-hidden">
                                <img id="social-preview-image" src="/static/images/default-event-preview.jpg" alt="Event preview" class="w-full h-full object-cover">
