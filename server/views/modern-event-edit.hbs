<script>
// Simplified Social Preview Functionality
document.addEventListener('DOMContentLoaded', function() {
    // Form elements
    const socialPreviewToggle = document.getElementById('social-preview-enabled');
    const socialPreviewFields = document.getElementById('social-preview-fields');
    const socialTitle = document.getElementById('social-title');
    const socialDescription = document.getElementById('social-description');
    const socialImage = document.getElementById('social-image');
    const socialImagePreview = document.getElementById('social-image-preview');
    const socialImageUpload = document.getElementById('social-image-upload');

    // Character count elements
    const titleCharCount = document.getElementById('title-char-count');
    const descriptionCharCount = document.getElementById('description-char-count');

    // Character count limits
    const titleLimit = 60; // Optimal for all platforms
    const descriptionLimit = 200; // Optimal for all platforms

    // Toggle social preview fields visibility
    function toggleSocialPreviewFields() {
        if (socialPreviewToggle?.checked) {
            socialPreviewFields?.classList.remove('opacity-50', 'pointer-events-none');
        } else {
            socialPreviewFields?.classList.add('opacity-50', 'pointer-events-none');
        }
    }

    // Update character counts (defensive - don't modify field values)
    function updateCharacterCounts() {
        if (socialTitle && titleCharCount) {
            const titleLength = socialTitle.value ? socialTitle.value.length : 0;
            titleCharCount.textContent = `${titleLength}/${titleLimit}`;
            titleCharCount.className = titleLength > titleLimit ? 'text-xs text-red-500' : 'text-xs text-gray-500';
        }

        if (socialDescription && descriptionCharCount) {
            const descLength = socialDescription.value ? socialDescription.value.length : 0;
            descriptionCharCount.textContent = `${descLength}/${descriptionLimit}`;
            descriptionCharCount.className = descLength > descriptionLimit ? 'text-xs text-red-500' : 'text-xs text-gray-500';
        }
    }

    // Update image preview
    function updateImagePreview(imageUrl) {
        if (socialImagePreview && imageUrl) {
            socialImagePreview.src = imageUrl;
        }
    }
    // Event listeners
    socialPreviewToggle?.addEventListener('change', toggleSocialPreviewFields);

    socialTitle?.addEventListener('input', updateCharacterCounts);
    socialDescription?.addEventListener('input', updateCharacterCounts);

    socialImage?.addEventListener('input', function() {
        updateImagePreview(this.value);
    });

    // Simplified image upload handling
    socialImageUpload?.addEventListener('change', async function(e) {
        const file = e.target.files[0];
        if (!file) return;

        // Validate file size (5MB limit)
        if (file.size > 5 * 1024 * 1024) {
            showToast('❌ Image too large. Please use an image under 5MB.', 'error', 3000);
            return;
        }

        // Validate file type
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
            showToast('❌ Invalid file type. Please upload JPG, PNG, or WebP images only.', 'error', 3000);
            return;
        }

        // Show upload progress
        showToast('📤 Uploading image...', 'info', 2000);

        try {
            // Create FormData for upload
            const formData = new FormData();
            formData.append('social_preview_image', file);

            // Upload to server
            const response = await fetch(`/api/events/{{event.id}}/social-preview/upload-image`, {
                method: 'POST',
                credentials: 'same-origin',
                body: formData
            });

            const result = await response.json();

            if (response.ok && result.success) {
                // Apply uploaded image URL to the universal field
                if (socialImage) {
                    socialImage.value = result.imageUrl;
                    updateImagePreview(result.imageUrl);
                }

                showToast('✅ Image uploaded successfully!', 'success', 3000);
            } else {
                throw new Error(result.error || 'Upload failed');
            }

        } catch (error) {
            console.error('Image upload error:', error);
            showToast(`❌ Upload failed: ${error.message}`, 'error', 5000);
        }

        // Clear the file input
        socialImageUpload.value = '';
    });

    // Social media cache invalidation functionality
    const invalidateCacheBtn = document.getElementById('invalidate-social-cache-btn');
    const cacheInfoDiv = document.getElementById('social-cache-info');

    invalidateCacheBtn?.addEventListener('click', async function() {
        try {
            // Show loading state
            this.disabled = true;
            this.innerHTML = `
                <svg class="w-4 h-4 mr-2 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Loading...
            `;

            // Fetch cache invalidation info
            const response = await fetch(`/api/events/{{event.id}}/social-preview/invalidate-cache`, {
                method: 'GET',
                credentials: 'same-origin'
            });

            const result = await response.json();

            if (response.ok && result.success) {
                // Update debugger links
                document.getElementById('facebook-debugger-link').href = result.data.socialPlatforms.facebook;
                document.getElementById('twitter-debugger-link').href = result.data.socialPlatforms.twitter;
                document.getElementById('linkedin-debugger-link').href = result.data.socialPlatforms.linkedin;

                // Show the cache info section
                cacheInfoDiv.classList.remove('hidden');

                showToast('✅ Social media debugger links generated! Click each link to refresh cached previews.', 'success', 5000);
            } else {
                throw new Error(result.message || 'Failed to generate debugger links');
            }

        } catch (error) {
            console.error('Cache invalidation error:', error);
            showToast(`❌ Failed to generate debugger links: ${error.message}`, 'error', 5000);
        } finally {
            // Restore button state
            this.disabled = false;
            this.innerHTML = `
                <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Test Social Previews
            `;
        }
    });

    // Initialize with delay to ensure form fields are populated
    setTimeout(() => {
        // Store original values to prevent accidental clearing
        const originalValues = {
            title: socialTitle?.value || '',
            description: socialDescription?.value || '',
            image: socialImage?.value || '',
            toggle: socialPreviewToggle?.checked || false
        };

        console.log('🔍 Social preview initialization - original field values:', originalValues);

        // Initialize functionality without modifying values
        toggleSocialPreviewFields();
        updateCharacterCounts();

        // Update image preview if there's already a value
        if (socialImage?.value) {
            updateImagePreview(socialImage.value);
        }

        // Verify values weren't accidentally cleared
        const afterValues = {
            title: socialTitle?.value || '',
            description: socialDescription?.value || '',
            image: socialImage?.value || '',
            toggle: socialPreviewToggle?.checked || false
        };

        console.log('🔍 Social preview initialization - after init values:', afterValues);

        // Restore values if they were accidentally cleared
        if (originalValues.title && !afterValues.title) {
            console.log('⚠️ Title was cleared, restoring:', originalValues.title);
            socialTitle.value = originalValues.title;
        }
        if (originalValues.description && !afterValues.description) {
            console.log('⚠️ Description was cleared, restoring:', originalValues.description);
            socialDescription.value = originalValues.description;
        }
        if (originalValues.image && !afterValues.image) {
            console.log('⚠️ Image was cleared, restoring:', originalValues.image);
            socialImage.value = originalValues.image;
        }

        // Update character counts again after any restoration
        updateCharacterCounts();

    }, 100);



});



// Enhanced QR Code & Social Preview Functionality
document.addEventListener('DOMContentLoaded', function() {
    // Mobile-optimized QR Code functionality
    const qrPreviewModal = document.getElementById('qr-preview-modal');
    const closeQrPreview = document.getElementById('close-qr-preview');
    const qrPreviewDisplay = document.getElementById('qr-preview-display');
    const downloadOptionsBtn = document.getElementById('download-options-btn');
    const downloadOptions = document.getElementById('download-options');

    // Enhanced Social Preview Modal
    const enhancedEditButton = document.getElementById('edit-social-preview-enhanced');
    const socialModal = document.getElementById('social-preview-modal');

    // Mobile-optimized QR Code copying with iOS Safari support
    window.copyQRCodeMobile = async function() {
        try {
            const qrImage = document.querySelector('#qr-code-display img');
            if (!qrImage || !qrImage.src) {
                showToast('❌ QR code not ready', 'error', 3000);
                return;
            }

            // Check if we're on iOS Safari
            const isIOSSafari = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

            if (isIOSSafari) {
                // iOS Safari fallback - create download link
                const link = document.createElement('a');
                link.href = qrImage.src;
                link.download = 'event-qr-code.png';
                link.target = '_blank';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                showToast('📱 QR code download started (iOS)', 'success', 3000);
            } else {
                // Modern browsers - use Clipboard API
                const response = await fetch(qrImage.src);
                const blob = await response.blob();

                if (navigator.clipboard && window.ClipboardItem) {
                    await navigator.clipboard.write([
                        new ClipboardItem({ [blob.type]: blob })
                    ]);
                    showToast('✅ QR code copied to clipboard!', 'success', 3000);
                } else {
                    // Fallback for older browsers
                    const link = document.createElement('a');
                    link.href = URL.createObjectURL(blob);
                    link.download = 'event-qr-code.png';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    URL.revokeObjectURL(link.href);
                    showToast('📥 QR code downloaded', 'success', 3000);
                }
            }
        } catch (error) {
            console.error('Failed to copy/download QR code:', error);
            showToast('❌ Failed to copy QR code', 'error', 3000);
        }
    };

    // Native Web Share API for mobile
    window.shareNatively = async function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        const title = document.getElementById('social-preview-title-display')?.textContent || 'Event';
        const text = document.getElementById('social-preview-description-display')?.textContent || 'Check out this event!';

        if (navigator.share) {
            try {
                await navigator.share({
                    title: title,
                    text: text,
                    url: url
                });
                showToast('✅ Event shared successfully!', 'success', 3000);
            } catch (error) {
                if (error.name !== 'AbortError') {
                    console.error('Error sharing:', error);
                    // Fallback to copy link
                    copyEventLinkEnhanced();
                }
            }
        } else {
            // Fallback for browsers without Web Share API
            copyEventLinkEnhanced();
        }
    };

    // Enhanced copy link with better mobile support
    window.copyEventLinkEnhanced = async function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        if (!url || url === 'Loading...') {
            showToast('❌ Event URL not ready', 'error', 3000);
            return;
        }

        try {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(url);
                showToast('✅ Event link copied to clipboard!', 'success', 3000);
            } else {
                // Fallback for older browsers or non-secure contexts
                const textArea = document.createElement('textarea');
                textArea.value = url;
                textArea.style.position = 'fixed';
                textArea.style.left = '-999999px';
                textArea.style.top = '-999999px';
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();

                try {
                    document.execCommand('copy');
                    showToast('✅ Event link copied!', 'success', 3000);
                } catch (err) {
                    showToast('❌ Failed to copy link', 'error', 3000);
                }

                document.body.removeChild(textArea);
            }
        } catch (error) {
            console.error('Failed to copy link:', error);
            showToast('❌ Failed to copy link', 'error', 3000);
        }
    };

    // Open QR Preview Modal with scroll position preservation
    window.openQRPreview = function() {
        const qrImage = document.querySelector('#qr-code-display img');
        if (qrImage && qrImage.src) {
            // Store current scroll position before opening modal
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;

            // Store scroll position for restoration
            qrPreviewModal.dataset.scrollTop = scrollTop;
            qrPreviewModal.dataset.scrollLeft = scrollLeft;

            qrPreviewDisplay.innerHTML = `<img src="${qrImage.src}" alt="QR Code Preview" class="w-full h-full object-contain">`;
            qrPreviewModal.classList.remove('hidden');
            qrPreviewModal.classList.add('flex');

            // Preserve scroll position when setting body overflow
            document.body.style.top = `-${scrollTop}px`;
            document.body.style.left = `-${scrollLeft}px`;
            document.body.style.position = 'fixed';
            document.body.style.width = '100%';
            document.body.style.overflow = 'hidden';
        }
    };

    // Close QR Preview Modal with scroll position restoration
    function closeQRPreview() {
        if (qrPreviewModal) {
            // Restore scroll position
            const scrollTop = parseInt(qrPreviewModal.dataset.scrollTop || '0');
            const scrollLeft = parseInt(qrPreviewModal.dataset.scrollLeft || '0');

            qrPreviewModal.classList.add('hidden');
            qrPreviewModal.classList.remove('flex');

            // Restore body styles
            document.body.style.position = '';
            document.body.style.top = '';
            document.body.style.left = '';
            document.body.style.width = '';
            document.body.style.overflow = '';

            // Restore scroll position
            window.scrollTo({
                top: scrollTop,
                left: scrollLeft,
                behavior: 'instant'
            });
        }
    }

    closeQrPreview?.addEventListener('click', closeQRPreview);
    qrPreviewModal?.addEventListener('click', function(e) {
        if (e.target === qrPreviewModal) {
            closeQRPreview();
        }
    });

    // Download Options Toggle
    downloadOptionsBtn?.addEventListener('click', function(e) {
        e.stopPropagation();
        downloadOptions?.classList.toggle('hidden');
    });

    // Close download options when clicking outside
    document.addEventListener('click', function(e) {
        if (downloadOptions && !downloadOptions.classList.contains('hidden') &&
            !downloadOptionsBtn?.contains(e.target) && !downloadOptions.contains(e.target)) {
            downloadOptions.classList.add('hidden');
        }
    });

    // Enhanced Social Preview Modal Event Listeners
    enhancedEditButton?.addEventListener('click', function() {
        // Populate modal with current values
        const titleInput = document.getElementById('social-title-input');
        const descriptionInput = document.getElementById('social-description-input');
        const imageInput = document.getElementById('social-image-input');

        if (titleInput) titleInput.value = document.getElementById('social-preview-title-display')?.textContent || '';
        if (descriptionInput) descriptionInput.value = document.getElementById('social-preview-description-display')?.textContent || '';
        if (imageInput) imageInput.value = document.getElementById('social-preview-image-display')?.src || '';

        // Update character counts
        updateCharacterCounts();
        window.updateAllPreviews();

        socialModal?.classList.add('active');
        document.body.style.overflow = 'hidden';
    });

    // Character count updates
    function updateCharacterCounts() {
        const titleInput = document.getElementById('social-title-input');
        const descriptionInput = document.getElementById('social-description-input');
        const titleCount = document.getElementById('title-char-count');
        const descriptionCount = document.getElementById('description-char-count');

        if (titleInput && titleCount) {
            titleCount.textContent = `${titleInput.value.length}/60`;
            titleCount.className = titleInput.value.length > 60 ? 'text-xs text-red-500' : 'text-xs text-gray-400';
        }

        if (descriptionInput && descriptionCount) {
            descriptionCount.textContent = `${descriptionInput.value.length}/160`;
            descriptionCount.className = descriptionInput.value.length > 160 ? 'text-xs text-red-500' : 'text-xs text-gray-400';
        }
    }

    // Update all preview tabs (moved to global scope)
    window.updateAllPreviews = function() {
        const title = document.getElementById('social-title-input')?.value || 'Event Title';
        const description = document.getElementById('social-description-input')?.value || 'Event description';
        const imageUrl = document.getElementById('social-image-input')?.value || '/static/images/default-event-preview.jpg';
        const eventUrl = '{{baseUrl}}/event/{{event.slug}}';
        const domain = '{{baseUrl}}';

        // Update iMessage preview
        const iMessageTitle = document.getElementById('imessage-preview-title');
        const iMessageDesc = document.getElementById('imessage-preview-description');
        const iMessageImage = document.getElementById('imessage-preview-image');
        const iMessageUrl = document.getElementById('imessage-preview-url');

        if (iMessageTitle) iMessageTitle.textContent = title;
        if (iMessageDesc) iMessageDesc.textContent = description;
        if (iMessageImage) iMessageImage.src = imageUrl;
        if (iMessageUrl) iMessageUrl.textContent = eventUrl;

        // Update WhatsApp preview
        const whatsappTitle = document.getElementById('whatsapp-preview-title');
        const whatsappDesc = document.getElementById('whatsapp-preview-description');
        const whatsappImage = document.getElementById('whatsapp-preview-image');
        const whatsappUrl = document.getElementById('whatsapp-preview-url');

        if (whatsappTitle) whatsappTitle.textContent = title;
        if (whatsappDesc) whatsappDesc.textContent = description;
        if (whatsappImage) whatsappImage.src = imageUrl;
        if (whatsappUrl) whatsappUrl.textContent = eventUrl;

        // Update Social Media preview
        const socialTitle = document.getElementById('social-preview-title');
        const socialDesc = document.getElementById('social-preview-description');
        const socialImage = document.getElementById('social-preview-image');
        const socialDomain = document.getElementById('social-preview-domain');

        if (socialTitle) socialTitle.textContent = title;
        if (socialDesc) socialDesc.textContent = description;
        if (socialImage) socialImage.src = imageUrl;
        if (socialDomain) socialDomain.textContent = domain;

        // Update main preview display
        const mainTitle = document.getElementById('social-preview-title-display');
        const mainDesc = document.getElementById('social-preview-description-display');
        const mainImage = document.getElementById('social-preview-image-display');

        if (mainTitle) mainTitle.textContent = title;
        if (mainDesc) mainDesc.textContent = description;
        if (mainImage) mainImage.src = imageUrl;
    };

    // Preview tab switching
    document.querySelectorAll('.preview-tab').forEach(tab => {
        tab.addEventListener('click', function() {
            // Remove active class from all tabs
            document.querySelectorAll('.preview-tab').forEach(t => {
                t.classList.remove('active', 'bg-white', 'text-blue-600');
                t.classList.add('text-gray-600');
            });

            // Add active class to clicked tab
            this.classList.add('active', 'bg-white', 'text-blue-600');
            this.classList.remove('text-gray-600');

            // Hide all preview content
            document.querySelectorAll('.preview-content').forEach(content => {
                content.classList.add('hidden');
            });

            // Show selected preview content
            const targetTab = this.getAttribute('data-tab');
            const targetContent = document.getElementById(`${targetTab}-preview`);
            if (targetContent) {
                targetContent.classList.remove('hidden');
            }
        });
    });

    // Real-time updates
    const titleInput = document.getElementById('social-title-input');
    const descriptionInput = document.getElementById('social-description-input');
    const imageInput = document.getElementById('social-image-input');

    titleInput?.addEventListener('input', function() {
        updateCharacterCounts();
        window.updateAllPreviews();
    });

    descriptionInput?.addEventListener('input', function() {
        updateCharacterCounts();
        window.updateAllPreviews();
    });

    imageInput?.addEventListener('input', function() {
        window.updateAllPreviews();
        // Update image preview
        const preview = document.getElementById('social-image-preview');
        if (preview && this.value) {
            preview.src = this.value;
        }
    });

    // Download QR Code Function
    window.downloadQR = function(format, size) {
        const eventId = {{event.id}};
        let sizeParam = '';
        let filename = `event-qr-code.${format}`;

        switch(size) {
            case 'small':
                sizeParam = '&size=192';
                filename = `event-qr-code-small.${format}`;
                break;
            case 'medium':
                sizeParam = '&size=512';
                filename = `event-qr-code-medium.${format}`;
                break;
            case 'large':
                sizeParam = '&size=1024';
                filename = `event-qr-code-large.${format}`;
                break;
            case 'vector':
                sizeParam = '';
                filename = `event-qr-code.svg`;
                break;
        }

        const downloadUrl = `/api/events/${eventId}/qr-code?format=${format}${sizeParam}`;

        // Create temporary download link
        const link = document.createElement('a');
        link.href = downloadUrl;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        // Hide download menu
        downloadMenu.classList.add('hidden');

        // Show success message
        showToast(`✅ QR code downloaded as ${format.toUpperCase()} (${size})`, 'success', 3000);
    };

    // Quick Share Functions
    window.shareViaWhatsApp = function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        const eventName = document.getElementById('edit-artist-name')?.value || 'Event';
        const message = `Check out this event: ${eventName}\n${url}`;
        const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(message)}`;
        window.open(whatsappUrl, '_blank');
    };

    window.shareViaEmail = function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        const eventName = document.getElementById('edit-artist-name')?.value || 'Event';
        const subject = `Invitation: ${eventName}`;
        const body = `You're invited to ${eventName}!\n\nEvent details: ${url}`;
        const emailUrl = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        window.location.href = emailUrl;
    };

    window.shareViaSMS = function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        const eventName = document.getElementById('edit-artist-name')?.value || 'Event';
        const message = `Check out this event: ${eventName} ${url}`;
        const smsUrl = `sms:?body=${encodeURIComponent(message)}`;
        window.location.href = smsUrl;
    };

    window.copyEventLink = function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        if (url && url !== 'Loading...') {
            navigator.clipboard.writeText(url).then(() => {
                showToast('✅ Event link copied to clipboard!', 'success', 3000);
            }).catch(() => {
                showToast('❌ Failed to copy link', 'error', 3000);
            });
        }
    };

    // Streamlined QR Code Event Listeners
    document.getElementById('copy-qr-btn')?.addEventListener('click', copyQRCodeMobile);
    document.getElementById('copy-url-btn')?.addEventListener('click', copyEventLinkEnhanced);
    document.getElementById('mobile-share-btn')?.addEventListener('click', shareNatively);

    // iMessage testing function
    window.testIMessagePreview = function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        if (url && url !== 'Loading...') {
            // Create a temporary text area with the URL for easy copying
            const textArea = document.createElement('textarea');
            textArea.value = url;
            textArea.style.position = 'fixed';
            textArea.style.left = '-999999px';
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();

            try {
                document.execCommand('copy');
                showToast('📱 URL copied! Paste in iMessage to test preview', 'success', 5000);
            } catch (err) {
                showToast('❌ Failed to copy URL for testing', 'error', 3000);
            }

            document.body.removeChild(textArea);
        } else {
            showToast('❌ Event URL not ready', 'error', 3000);
        }
    };

    // Enhanced WhatsApp sharing
    window.shareToWhatsApp = function() {
        const url = document.getElementById('qr-url-display-main')?.textContent;
        const title = document.getElementById('social-preview-title-display')?.textContent || 'Event';
        const message = `${title}\n\n${url}`;
        const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(message)}`;
        window.open(whatsappUrl, '_blank');
    };

    // Image upload handling
    document.getElementById('social-image-upload')?.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            if (file.size > 5 * 1024 * 1024) { // 5MB limit
                showToast('❌ Image too large. Please use an image under 5MB.', 'error', 3000);
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const imageUrl = e.target.result;
                document.getElementById('social-image-input').value = imageUrl;
                document.getElementById('social-image-preview').src = imageUrl;
                window.updateAllPreviews();
                showToast('✅ Image uploaded successfully!', 'success', 3000);
            };
            reader.readAsDataURL(file);
        }
    });

    // Test preview button
    document.getElementById('test-preview-btn')?.addEventListener('click', function() {
        testIMessagePreview();
    });

    // Update generation time
    function updateGenerationTime() {
        const timeElement = document.getElementById('qr-generation-time');
        if (timeElement) {
            timeElement.textContent = new Date().toLocaleTimeString();
        }
    }

    // Update QR stats (placeholder - will be populated by existing analytics)
    function updateQRStats() {
        // These will be updated by the existing loadQRCodeAnalytics function
        // Just ensuring the elements exist for the analytics to populate
        const scanCount = document.getElementById('qr-scan-count');
        const uniqueCount = document.getElementById('qr-unique-count');

        if (scanCount && scanCount.textContent === '-') {
            scanCount.textContent = '0';
        }
        if (uniqueCount && uniqueCount.textContent === '-') {
            uniqueCount.textContent = '0';
        }
    }

    // Initialize when QR code loads
    setTimeout(() => {
        updateGenerationTime();
        updateQRStats();
    }, 1000);
});
</script>

<style>
/* Enhanced QR Code Section Styles */
