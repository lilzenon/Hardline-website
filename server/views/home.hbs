              <div data-layer="Frame 9" class="Frame9" style="align-self: stretch; height: 25px; position: relative">
                {{#if this.event_date}}
                <div data-layer="DATE" class="Date" style="align-self: stretch; height: 14px; padding-left: 1px; justify-content: flex-start; align-items: center; gap: 4px; display: inline-flex">
                  <div data-svg-wrapper data-layer="Vector" class="Vector" style="position: relative">
                    <svg width="10" height="11" viewBox="0 0 10 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0.316456 4.25924H9.673C9.85232 4.25924 9.98945 4.1114 9.98945 3.94245C9.98945 3.7735 9.84177 3.62566 9.673 3.62566H0.316456C0.137131 3.62566 0 3.7735 0 3.94245C0 4.1114 0.147679 4.25924 0.316456 4.25924Z" fill="white"/>
                    </svg>
                  </div>
                  <div data-layer="Date" class="Date" style="width: 112px; height: 12px; color: white; font-size: 10px; font-family: Inter; font-weight: 200; word-wrap: break-word">{{formatDate this.event_date "EEE, MMM dd @ h:mm a"}}</div>
                </div>
                {{/if}}
                {{#if this.event_address}}
                <div data-layer="LOCATION" class="Location" style="align-self: stretch; height: 14px; padding-left: 1px; padding-right: 1px; justify-content: flex-start; align-items: center; gap: 4px; display: inline-flex">
                  <div data-svg-wrapper data-layer="Vector" class="Vector" style="position: relative">
                    <svg width="8" height="9" viewBox="0 0 8 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4.00001 8.9625C3.38335 8.9625 2.76251 8.72917 2.27918 8.26667C1.05001 7.08333 -0.308321 5.19583 0.204179 2.95C0.666679 0.9125 2.44585 0 4.00001 0C4.00001 0 4.00001 0 4.00418 0C5.55835 0 7.33751 0.9125 7.80001 2.95417C8.30835 5.2 6.95001 7.08333 5.72085 8.26667C5.23751 8.72917 4.61668 8.9625 4.00001 8.9625Z" fill="white"/>
                    </svg>
                  </div>
                  <div data-layer="Date" class="Date" style="width: 112px; height: 12px; color: white; font-size: 10px; font-family: Inter; font-weight: 200; word-wrap: break-word">{{this.event_address}}</div>
                </div>
                {{/if}}
              </div>
            </div>
            <div data-layer="Frame 9" class="Frame9" style="align-self: stretch; height: 25px; position: relative">
              <div data-layer="Card Buttons" class="CardButtons" style="width: 160px; height: 25px; padding-right: 4px; left: 0px; top: 0px; position: absolute; justify-content: space-between; align-items: flex-start; overflow: hidden; display: inline-flex">
                <div data-layer="Get Tickets" class="GetTickets" style="width: 160px; height: 25px; padding-left: 12px; padding-right: 12px; padding-top: 12px; padding-bottom: 12px; background: rgba(23, 23, 23, 0.80); overflow: hidden; border-radius: 37px; justify-content: center; align-items: center; gap: 10px; display: flex">
                  <div data-layer="Get Tickets" class="GetTickets" style="color: white; font-size: 12px; font-family: Inter; font-weight: 500; word-wrap: break-word">Get Tickets</div>
                </div>
                <div data-svg-wrapper data-layer="SHARE" class="Share" style="position: relative">
                  <svg width="26" height="25" viewBox="0 0 26 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="26" height="25" rx="12.5" fill="white"/>
                  <path d="M9.54652 9.56927C9.87209 9.545 10.1816 9.7883 10.2145 10.124C10.2472 10.4589 10.0023 10.7612 9.65981 10.7939C8.48877 10.902 7.69658 11.231 7.19496 11.8661C6.69191 12.5032 6.47233 13.4585 6.47231 14.8388V14.9365C6.47231 16.4592 6.74253 17.4752 7.37953 18.1122C8.01654 18.7492 9.03261 19.0195 10.5553 19.0195H15.445C16.9677 19.0195 17.9837 18.7492 18.6207 18.1122C19.2577 17.4752 19.528 16.4592 19.528 14.9365V14.8388C19.5279 13.4511 19.3047 12.4924 18.7926 11.8554C18.2818 11.2201 17.4747 10.8946 16.2809 10.7939H16.2799C15.9464 10.7612 15.6925 10.468 15.7252 10.1318C15.7537 9.8401 15.9758 9.60835 16.2614 9.57709H16.3864C17.8869 9.70527 18.9825 10.175 19.7008 11.0429C20.4182 11.9097 20.7526 13.1649 20.7526 14.8466V14.9443C20.7525 16.7837 20.3575 18.1108 19.4899 18.9765C18.6222 19.842 17.2917 20.2363 15.445 20.2363H10.5553C8.70862 20.2363 7.37807 19.8419 6.51039 18.9745C5.64272 18.1069 5.2477 16.7757 5.2477 14.9286V14.832C5.2477 13.1615 5.57685 11.9137 6.28285 11.0488C6.98976 10.183 8.06762 9.70877 9.54555 9.56927H9.54652Z" fill="black" stroke="black" stroke-width="0.1"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
        {{/each}}

      </div>
    </div>
  </div>
</div>
