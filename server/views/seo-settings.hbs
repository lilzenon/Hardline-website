{{!-- SEO Settings Page - Modern Laylo Dashboard Style --}}

<!-- SEO Settings Page -->
<div class="laylo-page">
    <!-- Page Header -->
    <div class="laylo-page-header">
        <div class="laylo-page-title">
            <h1>SEO Settings</h1>
            <p class="laylo-page-subtitle">Manage all SEO configurations and optimization settings for your platform</p>
        </div>
        <div class="laylo-page-actions">
            <button type="button" id="save-all-settings" class="laylo-btn laylo-btn-primary">
                <svg class="laylo-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17,21 17,13 7,13 7,21"/>
                    <polyline points="7,3 7,8 15,8"/>
                </svg>
                Save All Settings
            </button>
        </div>
    </div>

    <!-- Success/Error Messages -->
    <div id="message-container" class="laylo-alert" style="display: none;">
        <div id="message-content"></div>
    </div>

    <!-- Settings Content -->
    <div class="laylo-page-content">
        <div class="row">
            <!-- Settings Navigation -->
            <div class="col-lg-3">
                <div class="laylo-settings-nav">
                    <a href="#meta-tags" class="laylo-settings-nav-item active" data-section="meta-tags">
                        <svg class="laylo-settings-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                            <polyline points="14,2 14,8 20,8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <polyline points="10,9 9,9 8,9"/>
                        </svg>
                        Meta Tags
                    </a>
                    <a href="#analytics" class="laylo-settings-nav-item" data-section="analytics">
                        <svg class="laylo-settings-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 3v18h18"/>
                            <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>
                        </svg>
                        Analytics
                    </a>
                </div>
            </div>

            <!-- Settings Content -->
            <div class="col-lg-9">
                <form id="seo-settings-form">

                    <!-- Meta Tags Section -->
                    <div id="meta-tags-section" class="laylo-settings-section active">
                        <div class="laylo-card">
                            <div class="laylo-card-header">
                                <h3>Default Meta Tags</h3>
                                <p>Configure default meta tags used across your site when specific page meta tags are not available</p>
                            </div>
                            <div class="laylo-card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="laylo-form-group">
                                            <label for="default_title">Default Title</label>
                                            <input
                                                type="text"
                                                id="default_title"
                                                name="default_title"
                                                class="laylo-form-control"
                                                value="{{seoSettings.default_title}}"
                                                maxlength="60"
                                                required
                                            >
                                            <small class="laylo-form-text">Recommended: 50-60 characters</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="laylo-form-group">
                                            <label for="default_author">Default Author</label>
                                            <input
                                                type="text"
                                                id="default_author"
                                                name="default_author"
                                                class="laylo-form-control"
                                                value="{{seoSettings.default_author}}"
                                            >
                                        </div>
                                    </div>
                                </div>

                                <div class="laylo-form-group">
                                    <label for="default_description">Default Description</label>
                                    <textarea
