    <div class="flex items-center justify-center min-h-screen p-4">
        <!-- Modal Panel -->
        <div class="relative w-full max-w-2xl bg-white/10 backdrop-blur-xl rounded-3xl border border-white/20 shadow-2xl transform transition-all">
            <!-- Gradient Border Effect -->
            <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-purple-500/20 via-blue-500/20 to-indigo-500/20 p-[1px]">
                <div class="h-full w-full rounded-3xl bg-white/95 backdrop-blur-xl"></div>
            </div>

            <!-- Content -->
            <div class="relative p-8">
                <form id="keyword-form" class="space-y-6">
                    <!-- Header -->
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="text-xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent" id="keyword-form-title">
                                Add New Keyword
                            </h3>
                            <p class="text-gray-600 text-sm mt-1">Configure automated responses for Instagram comments</p>
                        </div>
                        <button type="button" onclick="closeKeywordFormModal()" class="p-2 rounded-full bg-gray-100 hover:bg-gray-200 transition-colors group">
                            <svg class="h-5 w-5 text-gray-500 group-hover:text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>

                    <!-- Form Fields -->
                    <div class="space-y-6">
                        <!-- Keyword Input -->
                        <div>
                            <label for="keyword-input" class="block text-sm font-semibold text-gray-700 mb-2">Keyword</label>
                            <input type="text" id="keyword-input" name="keyword" required
                                   class="w-full px-4 py-3 bg-white/70 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all placeholder-gray-400"
                                   placeholder="e.g., RSVP, TICKETS, INFO">
                            <p class="mt-2 text-xs text-gray-500">The word or phrase that will trigger the automation</p>
                        </div>

                        <!-- Description -->
                        <div>
                            <label for="keyword-description" class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
                            <textarea id="keyword-description" name="description" rows="2"
                                      class="w-full px-4 py-3 bg-white/70 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all placeholder-gray-400"
                                      placeholder="What does this keyword do?"></textarea>
                        </div>

                        <!-- Auto Response Message -->
                        <div>
                            <label for="auto-response" class="block text-sm font-semibold text-gray-700 mb-2">Auto Response Message</label>
                            <textarea id="auto-response" name="auto_response_message" rows="3"
                                      class="w-full px-4 py-3 bg-white/70 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all placeholder-gray-400"
                                      placeholder="Thanks for your interest! We'll send you updates soon."></textarea>
                            <p class="mt-2 text-xs text-gray-500">This message will be sent as a DM to users who comment with this keyword</p>
                        </div>

                        <!-- Options Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-4">
                                <div class="flex items-center p-3 bg-white/50 rounded-xl border border-gray-100">
                                    <input id="case-sensitive" name="case_sensitive" type="checkbox"
                                           class="h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded">
                                    <label for="case-sensitive" class="ml-3 text-sm font-medium text-gray-700">Case sensitive</label>
                                </div>

                                <div class="flex items-center p-3 bg-white/50 rounded-xl border border-gray-100">
                                    <input id="exact-match" name="exact_match" type="checkbox"
                                           class="h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded">
                                    <label for="exact-match" class="ml-3 text-sm font-medium text-gray-700">Exact match only</label>
                                </div>
                            </div>

                            <div class="space-y-4">
                                <div class="flex items-center p-3 bg-white/50 rounded-xl border border-gray-100">
                                    <input id="send-auto-response" name="send_auto_response" type="checkbox" checked
                                           class="h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded">
                                    <label for="send-auto-response" class="ml-3 text-sm font-medium text-gray-700">Send auto response</label>
                                </div>

                                <div class="flex items-center p-3 bg-white/50 rounded-xl border border-gray-100">
                                    <input id="capture-user-data" name="capture_user_data" type="checkbox" checked
                                           class="h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded">
                                    <label for="capture-user-data" class="ml-3 text-sm font-medium text-gray-700">Capture user data</label>
                                </div>
                            </div>
                        </div>

                        <!-- Signup Type -->
                        <div>
                            <label for="signup-type" class="block text-sm font-semibold text-gray-700 mb-2">Signup Type</label>
                            <select id="signup-type" name="signup_type"
                                    class="w-full px-4 py-3 bg-white/70 border border-gray-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all">
                                <option value="general">General Interest</option>
                                <option value="event">Event RSVP</option>
                                <option value="newsletter">Newsletter Signup</option>
                                <option value="product">Product Interest</option>
                                <option value="custom">Custom</option>
                            </select>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex justify-end space-x-4 pt-6 border-t border-gray-200">
                        <button type="button" onclick="closeKeywordFormModal()"
                                class="px-6 py-3 bg-gray-100 text-gray-700 font-medium rounded-xl hover:bg-gray-200 transition-colors">
                            Cancel
                        </button>
                        <button type="submit"
                                class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium rounded-xl hover:from-purple-700 hover:to-blue-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl">
                            <span id="keyword-form-submit-text">Create Keyword</span>
                            <div id="keyword-form-loading" class="hidden ml-2">
                                <div class="animate-spin rounded-full h-4 w-4 border-2 border-white border-t-transparent"></div>
                            </div>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modern Dashboard JavaScript for Settings -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    console.log('⚙️ Settings page loaded');

    // Mobile settings menu functionality
    const mobileMenuButton = document.getElementById('mobile-settings-menu');
    const mobileMenuNav = document.getElementById('mobile-settings-nav');
    const mobileCurrentText = document.getElementById('mobile-settings-current');

    if (mobileMenuButton && mobileMenuNav) {
        mobileMenuButton.addEventListener('click', function() {
            const isExpanded = this.getAttribute('aria-expanded') === 'true';
            this.setAttribute('aria-expanded', !isExpanded);

            if (isExpanded) {
                mobileMenuNav.classList.add('hidden');
                mobileMenuNav.classList.remove('block');
            } else {
                mobileMenuNav.classList.remove('hidden');
                mobileMenuNav.classList.add('block');
            }
        });
    }

    // Initialize modern dashboard navigation
    const navItems = document.querySelectorAll('.settings-nav-item');
    const sections = document.querySelectorAll('.settings-section');

    function switchToSection(targetSection, sectionName) {
        // Remove active classes from all nav items
        navItems.forEach(nav => {
            nav.classList.remove('bg-blue-50', 'border-blue-500', 'text-blue-700');
            nav.classList.add('border-transparent', 'text-gray-900', 'hover:bg-gray-50', 'hover:text-gray-900');
            nav.setAttribute('aria-selected', 'false');
            const svg = nav.querySelector('svg');
            if (svg) {
                svg.classList.remove('text-blue-500');
                svg.classList.add('text-gray-400', 'group-hover:text-gray-500');
            }
        });

        // Hide all sections
        sections.forEach(section => {
            section.classList.add('hidden');
        });

        // Find and activate the target nav item
        const targetNavItem = document.querySelector(`[data-section="${targetSection}"]`);
        if (targetNavItem) {
            targetNavItem.classList.remove('border-transparent', 'text-gray-900', 'hover:bg-gray-50', 'hover:text-gray-900');
            targetNavItem.classList.add('bg-blue-50', 'border-blue-500', 'text-blue-700');
            targetNavItem.setAttribute('aria-selected', 'true');
            const svg = targetNavItem.querySelector('svg');
            if (svg) {
                svg.classList.remove('text-gray-400', 'group-hover:text-gray-500');
                svg.classList.add('text-blue-500');
            }
        }

        // Show target section
        const targetElement = document.getElementById(targetSection + '-section');
        if (targetElement) {
            targetElement.classList.remove('hidden');
        }

        // Update mobile menu current text
        if (mobileCurrentText && sectionName) {
            mobileCurrentText.textContent = sectionName;
        }

        // Close mobile menu
        if (mobileMenuButton && mobileMenuNav) {
            mobileMenuButton.setAttribute('aria-expanded', 'false');
            mobileMenuNav.classList.add('hidden');
            mobileMenuNav.classList.remove('block');
        }

        console.log(`📋 Switched to section: ${targetSection}`);
    }

    navItems.forEach(item => {
        item.addEventListener('click', function(e) {
            e.preventDefault();

            const targetSection = this.getAttribute('data-section');
            const sectionName = this.querySelector('span').textContent.trim();

            switchToSection(targetSection, sectionName);
        });
    });

    // SEO Tab functionality with keyboard navigation
    const seoTabButtons = document.querySelectorAll('.seo-tab-button');
    const seoTabContents = document.querySelectorAll('.seo-tab-content');

    function switchSEOTab(targetTab) {
        // Remove active classes from all tab buttons
        seoTabButtons.forEach(btn => {
            btn.classList.remove('border-blue-500', 'text-blue-600', 'active');
            btn.classList.add('border-transparent', 'text-gray-500', 'hover:text-gray-700', 'hover:border-gray-300');
            btn.setAttribute('aria-selected', 'false');
            btn.setAttribute('tabindex', '-1');
        });

        // Hide all tab contents
        seoTabContents.forEach(content => {
            content.classList.add('hidden');
        });

        // Find and activate target button
        const targetButton = document.querySelector(`[data-tab="${targetTab}"]`);
        if (targetButton) {
            targetButton.classList.remove('border-transparent', 'text-gray-500', 'hover:text-gray-700', 'hover:border-gray-300');
            targetButton.classList.add('border-blue-500', 'text-blue-600', 'active');
            targetButton.setAttribute('aria-selected', 'true');
            targetButton.setAttribute('tabindex', '0');
        }

        // Show target tab content
        const targetContent = document.getElementById(targetTab + '-tab');
        if (targetContent) {
            targetContent.classList.remove('hidden');
        }

        console.log(`🔧 Switched to SEO tab: ${targetTab}`);
    }

    seoTabButtons.forEach((button, index) => {
        button.addEventListener('click', function() {
            const targetTab = this.getAttribute('data-tab');
            switchSEOTab(targetTab);
        });

        // Keyboard navigation for tabs
        button.addEventListener('keydown', function(e) {
            let targetIndex;

            switch(e.key) {
                case 'ArrowLeft':
                    e.preventDefault();
                    targetIndex = index > 0 ? index - 1 : seoTabButtons.length - 1;
                    seoTabButtons[targetIndex].focus();
                    switchSEOTab(seoTabButtons[targetIndex].getAttribute('data-tab'));
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    targetIndex = index < seoTabButtons.length - 1 ? index + 1 : 0;
                    seoTabButtons[targetIndex].focus();
                    switchSEOTab(seoTabButtons[targetIndex].getAttribute('data-tab'));
                    break;
                case 'Home':
                    e.preventDefault();
                    seoTabButtons[0].focus();
                    switchSEOTab(seoTabButtons[0].getAttribute('data-tab'));
                    break;
                case 'End':
                    e.preventDefault();
                    seoTabButtons[seoTabButtons.length - 1].focus();
                    switchSEOTab(seoTabButtons[seoTabButtons.length - 1].getAttribute('data-tab'));
                    break;
            }
        });
    });

    // Save settings functionality
    const saveButton = document.getElementById('save-all-settings');
    if (saveButton) {
        saveButton.addEventListener('click', async function() {
            console.log('💾 Saving settings...');

            // Validate form before saving
            if (!validateForm()) {
                showMessage('Please fill in all required fields.', 'error');
                return;
            }

            const form = document.getElementById('settings-form');
            const formData = new FormData(form);

            // Show loading state
            this.disabled = true;
            const originalHTML = this.innerHTML;
            this.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Saving...';
            this.setAttribute('aria-busy', 'true');

            try {
                const response = await fetch('/dashboard/settings', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    showMessage('Settings saved successfully!', 'success');
                    console.log('✅ Settings saved');
                } else {
                    showMessage(result.error || 'Failed to save settings', 'error');
                    console.error('❌ Error saving settings:', result.error);
                }
            } catch (error) {
                console.error('❌ Network error:', error);
                showMessage('Network error. Please try again.', 'error');
            } finally {
                // Reset button state
                this.disabled = false;
                this.innerHTML = originalHTML;
                this.removeAttribute('aria-busy');
            }
        });
    }

    // Form validation
    function validateForm() {
        const form = document.getElementById('settings-form');
        const requiredFields = form.querySelectorAll('[required]');
        let isValid = true;

        requiredFields.forEach(field => {
            const value = field.value.trim();
            const errorId = field.id + '_error';
            let errorElement = document.getElementById(errorId);

            // Remove existing error styling
            field.classList.remove('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');
            field.setAttribute('aria-invalid', 'false');

            if (errorElement) {
                errorElement.remove();
            }

            if (!value) {
                isValid = false;

                // Add error styling
                field.classList.add('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');
                field.setAttribute('aria-invalid', 'true');

                // Create error message
                errorElement = document.createElement('p');
                errorElement.id = errorId;
                errorElement.className = 'mt-1 text-sm text-red-600';
                errorElement.textContent = 'This field is required';
                errorElement.setAttribute('role', 'alert');

                field.parentNode.appendChild(errorElement);
                field.setAttribute('aria-describedby', field.getAttribute('aria-describedby') + ' ' + errorId);
            }
        });

        return isValid;
    }

    // Instagram Integration functionality
    const connectInstagramBtn = document.getElementById('connect-instagram-btn');
    const reconnectInstagramBtn = document.getElementById('reconnect-instagram-btn');
    const disconnectInstagramBtn = document.getElementById('disconnect-instagram-btn');
    const instagramSettingsBtn = document.getElementById('instagram-settings-btn');

    // Store current Instagram account ID for keyword management
    let currentInstagramAccountId = null;
    const instagramStatus = document.getElementById('instagram-status');
    const statusText = document.getElementById('status-text');
    const statusLoading = document.getElementById('status-loading');
    const accountDetails = document.getElementById('instagram-account-details');

    // Show loading state
    function showLoadingState(message = 'Loading...') {
        statusText.textContent = message;
        statusLoading.classList.remove('hidden');
        instagramStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800';
    }

    // Hide loading state
    function hideLoadingState() {
        statusLoading.classList.add('hidden');
    }

    // Update connection button state
    function updateConnectionButton(isConnected, isLoading = false) {
        const btnText = document.getElementById('connect-btn-text');
        const btnIcon = document.getElementById('connect-btn-icon');
        const btnLoading = document.getElementById('connect-btn-loading');

        if (isLoading) {
            btnIcon.classList.add('hidden');
            btnLoading.classList.remove('hidden');
            btnText.textContent = 'Connecting...';
            connectInstagramBtn.disabled = true;
        } else {
            btnIcon.classList.remove('hidden');
            btnLoading.classList.add('hidden');
            connectInstagramBtn.disabled = false;

            if (isConnected) {
                btnText.textContent = 'Connected';
                connectInstagramBtn.classList.add('hidden');
                reconnectInstagramBtn.classList.remove('hidden');
            } else {
                btnText.textContent = 'Connect Instagram';
                connectInstagramBtn.classList.remove('hidden');
                reconnectInstagramBtn.classList.add('hidden');
            }
        }
    }

    // Display account details
    function displayAccountDetails(account) {
        if (!account) return;

        // Store the account ID for keyword management
        currentInstagramAccountId = account.id;
        console.log('Stored Instagram account ID:', currentInstagramAccountId);

        document.getElementById('account-profile-picture').src = account.profile_picture || '/images/default-avatar.png';
        document.getElementById('account-username').textContent = '@' + (account.username || 'unknown');
        document.getElementById('account-name').textContent = account.name || 'Instagram Business Account';
        document.getElementById('account-type').textContent = (account.account_type || 'business').toUpperCase();
        document.getElementById('follower-count').textContent = formatNumber(account.follower_count || 0);

        const connectedDate = new Date(account.connected_at);
        document.getElementById('connected-date').textContent = connectedDate.toLocaleDateString();

        accountDetails.classList.remove('hidden');
    }

    // Hide account details
    function hideAccountDetails() {
        accountDetails.classList.add('hidden');
    }

    // Format number with commas
    function formatNumber(num) {
        return new Intl.NumberFormat().format(num);
    }

    // Load Instagram status on page load
    async function loadInstagramStatus() {
        try {
            showLoadingState('Checking connection...');

            const response = await fetch('/api/integrations/instagram/status');
            const data = await response.json();

            hideLoadingState();

            if (data.success && data.connected && data.accounts.length > 0) {
                // Connected state
                statusText.textContent = 'Connected';
                instagramStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800';

                updateConnectionButton(true);
                displayAccountDetails(data.accounts[0]);

                // Enable settings button
                instagramSettingsBtn.disabled = false;
                instagramSettingsBtn.classList.remove('disabled:opacity-50', 'disabled:cursor-not-allowed');

            } else {
                // Not connected state
                statusText.textContent = 'Not Connected';
                instagramStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800';

                updateConnectionButton(false);
                hideAccountDetails();

                // Disable settings button
                instagramSettingsBtn.disabled = true;
                instagramSettingsBtn.classList.add('disabled:opacity-50', 'disabled:cursor-not-allowed');
            }
        } catch (error) {
            console.error('❌ Error loading Instagram status:', error);
            hideLoadingState();
            statusText.textContent = 'Error';
            instagramStatus.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800';
            updateConnectionButton(false);
            hideAccountDetails();
        }
    }

    // Connect Instagram button click
    if (connectInstagramBtn) {
        connectInstagramBtn.addEventListener('click', function() {
            if (connectInstagramBtn.disabled) return;

            updateConnectionButton(false, true);
            showLoadingState('Redirecting to Instagram Business authentication...');

            const returnUrl = encodeURIComponent(window.location.href);

            // Add a small delay to show loading state
            setTimeout(() => {
                window.location.href = `/api/integrations/instagram/auth?returnUrl=${returnUrl}`;
            }, 500);
        });
    }

    // Reconnect Instagram button click
    if (reconnectInstagramBtn) {
        reconnectInstagramBtn.addEventListener('click', function() {
            if (confirm('Are you sure you want to reconnect your Instagram account? This will refresh your connection and permissions.')) {
                updateConnectionButton(false, true);
                showLoadingState('Reconnecting...');

                const returnUrl = encodeURIComponent(window.location.href);

                setTimeout(() => {
                    window.location.href = `/api/integrations/instagram/auth?returnUrl=${returnUrl}`;
                }, 500);
            }
        });
    }

    // Disconnect Instagram button click
    if (disconnectInstagramBtn) {
        disconnectInstagramBtn.addEventListener('click', async function() {
            if (!confirm('Are you sure you want to disconnect your Instagram account? This will stop all automation and remove access to your Instagram data.')) {
                return;
            }

            try {
                showLoadingState('Disconnecting...');

                // Get the account ID from the current status
                const statusResponse = await fetch('/api/integrations/instagram/status');
                const statusData = await statusResponse.json();

                if (statusData.success && statusData.accounts.length > 0) {
                    const accountId = statusData.accounts[0].id;

                    const response = await fetch(`/api/integrations/instagram/${accountId}`, {
                        method: 'DELETE'
                    });

                    const data = await response.json();

                    if (data.success) {
                        showNotification('Instagram account disconnected successfully', 'success');
                        loadInstagramStatus();
                        loadIntegrationStats();
                        loadKeywordAnalytics();
                    } else {
                        throw new Error(data.error || 'Failed to disconnect account');
                    }
                } else {
                    throw new Error('No connected account found');
                }
            } catch (error) {
                console.error('❌ Error disconnecting Instagram:', error);
                showNotification('Failed to disconnect Instagram account: ' + error.message, 'error');
                loadInstagramStatus(); // Reload to show current state
            }
        });
    }

    // Instagram settings button click
    if (instagramSettingsBtn) {
        instagramSettingsBtn.addEventListener('click', function() {
            if (instagramSettingsBtn.disabled) return;

            if (!currentInstagramAccountId) {
                showNotification('No Instagram account connected. Please connect an account first.', 'error');
                return;
            }

            console.log('Opening keyword modal for account:', currentInstagramAccountId);
            openKeywordModal(currentInstagramAccountId);
        });
    }

    // Load integration stats
    async function loadIntegrationStats() {
        try {
            const response = await fetch('/api/integrations/stats');
            const data = await response.json();

            if (data.success) {
                // Original stats
                document.getElementById('total-captured').textContent = data.stats.total_captured || 0;
                document.getElementById('total-responses').textContent = data.stats.total_responses || 0;
                document.getElementById('active-keywords').textContent = data.stats.active_keywords || 0;

                // Enhanced keyword analytics
                const keywordTriggersEl = document.getElementById('total-keyword-triggers');
                const keywordResponsesEl = document.getElementById('total-keyword-responses');
                const triggeredKeywordsEl = document.getElementById('triggered-keywords');

                if (keywordTriggersEl) keywordTriggersEl.textContent = data.stats.total_keyword_triggers || 0;
                if (keywordResponsesEl) keywordResponsesEl.textContent = data.stats.total_keyword_responses || 0;
                if (triggeredKeywordsEl) triggeredKeywordsEl.textContent = data.stats.triggered_keywords || 0;
            }
        } catch (error) {
            console.error('❌ Error loading integration stats:', error);
        }
    }

    // Load detailed keyword analytics
    async function loadKeywordAnalytics() {
        try {
            const response = await fetch('/api/integrations/keyword-analytics?limit=5');
            const data = await response.json();

            if (data.success && data.analytics) {
                const container = document.getElementById('keyword-analytics-list');
                if (container) {
                    container.innerHTML = data.analytics.map(keyword => `
                        <div class="keyword-analytics-item">
                            <div class="keyword-info">
                                <span class="keyword-text">${keyword.keyword}</span>
                                <span class="keyword-type">${keyword.keyword_type}</span>
                            </div>
                            <div class="keyword-stats">
                                <span class="stat-item">
                                    <span class="stat-value">${keyword.total_triggers || 0}</span>
                                    <span class="stat-label">Triggers</span>
                                </span>
                                <span class="stat-item">
                                    <span class="stat-value">${keyword.total_responses_sent || 0}</span>
                                    <span class="stat-label">Responses</span>
                                </span>
                            </div>
                        </div>
                    `).join('');
                }
            }
        } catch (error) {
            console.error('❌ Error loading keyword analytics:', error);
        }
    }

    // Check for URL parameters (success/error messages)
    function checkUrlParams() {
        const urlParams = new URLSearchParams(window.location.search);
        const success = urlParams.get('success');
        const error = urlParams.get('error');
        const errorDescription = urlParams.get('error_description');

        if (success === 'instagram_connected') {
            showNotification('🎉 Instagram account connected successfully! You can now create keywords and start automating responses.', 'success');
            loadInstagramStatus();
            loadIntegrationStats();
            loadKeywordAnalytics();
            // Clean up URL
            window.history.replaceState({}, document.title, window.location.pathname + window.location.hash);
        } else if (success === 'instagram_reconnected') {
            showNotification('✅ Instagram account reconnected successfully! Your permissions have been refreshed.', 'success');
            loadInstagramStatus();
            loadIntegrationStats();
            loadKeywordAnalytics();
            // Clean up URL
            window.history.replaceState({}, document.title, window.location.pathname + window.location.hash);
        } else if (error) {
            let errorMessage = 'An error occurred while connecting to Instagram';
            let helpText = '';

            switch (error) {
                case 'oauth_failed':
                case 'access_denied':
                    errorMessage = 'Instagram authentication was cancelled or failed';
                    helpText = 'Please try again and make sure to grant all required permissions.';
                    break;
                case 'no_business_accounts':
                    errorMessage = 'No Instagram Business accounts found';
                    helpText = 'Please ensure your Instagram account is set to Business mode (not Creator or Personal) and is connected to a Facebook Page.';
                    break;
                case 'invalid_state':
                    errorMessage = 'Security validation failed';
                    helpText = 'Please try connecting again. This helps protect your account from unauthorized access.';
                    break;
                case 'not_business_account':
                    errorMessage = 'Instagram account is not a Business account';
                    helpText = 'Keyword automation requires an Instagram Business account. Please switch your account to Business mode in Instagram settings.';
                    break;
                case 'invalid_credentials':
                    errorMessage = 'Invalid App ID or App Secret';
                    helpText = 'Please check that your Meta App Dashboard credentials are correctly configured in the environment variables.';
                    break;
                case 'invalid_redirect_uri':
                    errorMessage = 'Invalid redirect URI configuration';
                    helpText = 'Please ensure your Meta App Dashboard has the correct OAuth redirect URI: https://b2b.click/api/integrations/instagram/callback';
                    break;
                case 'invalid_code':
                    errorMessage = 'Authorization code expired or invalid';
                    helpText = 'Please try connecting again. Authorization codes expire quickly for security.';
                    break;
                case 'api_field_error':
                    errorMessage = 'Facebook Graph API field error';
                    helpText = 'The Facebook Graph API version has changed. This has been automatically updated - please try connecting again.';
                    break;
                case 'insufficient_permissions':
                    errorMessage = 'Insufficient Facebook permissions';
                    helpText = 'Please ensure you grant all requested permissions during the Facebook OAuth process, including access to your Facebook Pages and Instagram Business accounts.';
                    break;
                case 'api_error':
                    errorMessage = 'Facebook Graph API error';
                    helpText = 'There was an error communicating with Facebook\'s API. Please try again in a few minutes.';
                    break;
                case 'callback_failed':
                    errorMessage = 'Failed to complete Instagram connection';
                    helpText = 'There was a technical issue. Please try again in a few moments.';
                    break;
                case 'invalid_callback':
                    errorMessage = 'Invalid authentication response';
                    helpText = 'Please try connecting again. If the issue persists, contact support.';
                    break;
                case 'permissions_denied':
                    errorMessage = 'Required permissions were not granted';
                    helpText = 'Instagram integration requires access to manage comments and messages. Please grant all permissions when connecting.';
                    break;
                case 'account_not_eligible':
                    errorMessage = 'Instagram account is not eligible for business features';
                    helpText = 'Please ensure your Instagram account is a Business or Creator account with an active Facebook Page connection.';
                    break;
                default:
                    if (errorDescription) {
                        errorMessage = errorDescription;
                    }
                    helpText = 'Please try again or contact support if the issue persists.';
            }

            // Show detailed error notification
            const fullMessage = helpText ? `${errorMessage}. ${helpText}` : errorMessage;
            showNotification(fullMessage, 'error');

            // Reset UI state
            updateConnectionButton(false);
            hideAccountDetails();

            // Clean up URL
            window.history.replaceState({}, document.title, window.location.pathname + window.location.hash);
        }
    }

    // Show notification function
    function showNotification(message, type = 'info', duration = 8000) {
        // Remove any existing notifications
        const existingNotifications = document.querySelectorAll('.instagram-notification');
        existingNotifications.forEach(notif => notif.remove());

        // Create notification element
        const notification = document.createElement('div');
        notification.className = `instagram-notification fixed top-4 right-4 z-50 max-w-md w-full bg-white shadow-lg rounded-lg pointer-events-auto ring-1 ring-black ring-opacity-5 overflow-hidden transform transition-all duration-300 translate-x-full`;

        const bgColor = type === 'success' ? 'bg-green-50' : type === 'error' ? 'bg-red-50' : 'bg-blue-50';
        const textColor = type === 'success' ? 'text-green-800' : type === 'error' ? 'text-red-800' : 'text-blue-800';
        const iconColor = type === 'success' ? 'text-green-400' : type === 'error' ? 'text-red-400' : 'text-blue-400';
        const borderColor = type === 'success' ? 'border-green-200' : type === 'error' ? 'border-red-200' : 'border-blue-200';

        notification.innerHTML = `
            <div class="border-l-4 ${borderColor} ${bgColor} p-4">
                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <svg class="h-6 w-6 ${iconColor}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            ${type === 'success' ?
                                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />' :
                                type === 'error' ?
                                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />' :
                                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />'
                            }
                        </svg>
                    </div>
                    <div class="ml-3 w-0 flex-1">
                        <p class="text-sm font-medium ${textColor} leading-relaxed">${message}</p>
                    </div>
                    <div class="ml-4 flex-shrink-0 flex">
                        <button class="bg-white rounded-md inline-flex text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 p-1" onclick="this.closest('.instagram-notification').remove()">
                            <span class="sr-only">Close</span>
                            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        `;

        document.body.appendChild(notification);

        // Animate in
        setTimeout(() => {
            notification.classList.remove('translate-x-full');
        }, 100);

        // Auto-remove after specified duration
        setTimeout(() => {
            if (notification.parentNode) {
                notification.classList.add('translate-x-full');
                setTimeout(() => {
                    if (notification.parentNode) {
                        notification.remove();
                    }
                }, 300);
            }
        }, duration);
    }

    // Initialize integrations functionality when on integrations section
    if (window.location.hash === '#integrations') {
        loadInstagramStatus();
        loadIntegrationStats();
        loadKeywordAnalytics();
    }

    // Load when switching to integrations section
    const integrationsNavItem = document.querySelector('[data-section="integrations"]');
    if (integrationsNavItem) {
        integrationsNavItem.addEventListener('click', function() {
            setTimeout(() => {
                loadInstagramStatus();
                loadIntegrationStats();
                loadKeywordAnalytics();
            }, 100);
        });
    }

    // Check URL params on page load
    checkUrlParams();

    function showMessage(message, type) {
        const container = document.getElementById('message-container');
        const content = document.getElementById('message-content');

        if (container && content) {
            content.textContent = message;

            // Remove existing classes
            content.className = 'rounded-md p-4';

            // Add appropriate styling based on type
            if (type === 'success') {
                content.classList.add('bg-green-50', 'text-green-800', 'border', 'border-green-200');
                content.setAttribute('role', 'status');
            } else {
                content.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
                content.setAttribute('role', 'alert');
            }

            container.classList.remove('hidden');

            // Focus the message for screen readers
            content.setAttribute('tabindex', '-1');
            content.focus();

            setTimeout(() => {
                container.classList.add('hidden');
                content.removeAttribute('tabindex');
            }, 5000);
        }
    }

    // Handle URL hash for direct section navigation
    function handleHashNavigation() {
        const hash = window.location.hash.substring(1);
        if (hash) {
            const sectionNames = {
                'seo': 'SEO & Optimization',
                'general': 'General',
                'notifications': 'Notifications',
                'security': 'Security',
                'integrations': 'Integrations'
            };

            if (sectionNames[hash]) {
                switchToSection(hash, sectionNames[hash]);
            }
        }
    }

    // Handle hash changes
    window.addEventListener('hashchange', handleHashNavigation);

    // Handle initial hash on page load
    handleHashNavigation();

    // Character counters
    function setupCharacterCounter(inputId, counterId, maxLength) {
        const input = document.getElementById(inputId);
        const counter = document.getElementById(counterId);

        if (input && counter) {
            function updateCounter() {
                const currentLength = input.value.length;
                counter.textContent = `${currentLength}/${maxLength}`;

                // Color coding based on usage
                if (currentLength > maxLength * 0.9) {
                    counter.classList.remove('text-gray-400', 'text-yellow-500');
                    counter.classList.add('text-red-500');
                } else if (currentLength > maxLength * 0.7) {
                    counter.classList.remove('text-gray-400', 'text-red-500');
                    counter.classList.add('text-yellow-500');
                } else {
                    counter.classList.remove('text-red-500', 'text-yellow-500');
                    counter.classList.add('text-gray-400');
                }
            }

            // Update on input
            input.addEventListener('input', updateCounter);

            // Initial update
            updateCounter();
        }
    }

    // Setup character counters
    setupCharacterCounter('default_title', 'default_title_counter', 60);
    setupCharacterCounter('default_description', 'default_description_counter', 160);

    // Auto-save draft functionality (optional enhancement)
    let autoSaveTimeout;
    const form = document.getElementById('settings-form');

    if (form) {
        form.addEventListener('input', function() {
            clearTimeout(autoSaveTimeout);
            autoSaveTimeout = setTimeout(() => {
                // Save draft to localStorage
                const formData = new FormData(form);
                const draftData = {};
                for (let [key, value] of formData.entries()) {
                    draftData[key] = value;
                }
                localStorage.setItem('settings_draft', JSON.stringify(draftData));
                console.log('📝 Draft saved automatically');
            }, 2000); // Save after 2 seconds of inactivity
        });

        // Load draft on page load
        const savedDraft = localStorage.getItem('settings_draft');
        if (savedDraft) {
            try {
                const draftData = JSON.parse(savedDraft);
                Object.keys(draftData).forEach(key => {
                    const field = form.querySelector(`[name="${key}"]`);
                    if (field && !field.value) {
                        field.value = draftData[key];
                        // Trigger input event to update character counters
                        field.dispatchEvent(new Event('input'));
                    }
                });
                console.log('📝 Draft loaded from previous session');
            } catch (e) {
                console.warn('Failed to load draft:', e);
            }
        }
    }

    // Keyword Management JavaScript
    let currentEditingKeyword = null;
    let currentSocialAccountId = null;

    // Open keyword management modal
    function openKeywordModal(socialAccountId = null) {
        // Set the current social account ID for keyword operations
        currentSocialAccountId = socialAccountId;

        console.log('Opening keyword modal for social account:', socialAccountId);

        document.getElementById('keyword-management-modal').classList.remove('hidden');
        loadKeywords();
    }

    // Close keyword management modal
    function closeKeywordModal() {
        document.getElementById('keyword-management-modal').classList.add('hidden');
    }

    // Open keyword form modal
    function openKeywordFormModal(keyword = null) {
        currentEditingKeyword = keyword;
        const modal = document.getElementById('keyword-form-modal');
        const title = document.getElementById('keyword-form-title');
        const submitText = document.getElementById('keyword-form-submit-text');
        const form = document.getElementById('keyword-form');

        if (keyword) {
            title.textContent = 'Edit Keyword';
            submitText.textContent = 'Update Keyword';
            populateKeywordForm(keyword);
        } else {
            title.textContent = 'Add New Keyword';
            submitText.textContent = 'Create Keyword';
            form.reset();
        }

        modal.classList.remove('hidden');
    }

    // Close keyword form modal
    function closeKeywordFormModal() {
        document.getElementById('keyword-form-modal').classList.add('hidden');
    }

    // Load keywords from API
    async function loadKeywords() {
        const loadingEl = document.getElementById('keywords-loading');
        const emptyEl = document.getElementById('keywords-empty');
        const listEl = document.getElementById('keywords-list');

        console.log('Loading keywords for social account:', currentSocialAccountId);

        loadingEl.classList.remove('hidden');
        emptyEl.classList.add('hidden');
        listEl.innerHTML = '';

        try {
            // Build URL with social account ID if available
            let url = '/api/integrations/keywords';
            if (currentSocialAccountId) {
                url += `?social_account_id=${currentSocialAccountId}`;
            }

            console.log('Fetching keywords from:', url);
            const response = await fetch(url);
            const data = await response.json();

            console.log('Keywords response:', data);

            loadingEl.classList.add('hidden');

            if (data.success && data.keywords.length > 0) {
                renderKeywords(data.keywords);
            } else {
                emptyEl.classList.remove('hidden');
                console.log('No keywords found or empty response');
            }
        } catch (error) {
            console.error('Error loading keywords:', error);
            loadingEl.classList.add('hidden');
            emptyEl.classList.remove('hidden');
        }
    }

    // Render keywords list with modern styling
    function renderKeywords(keywords) {
        const listEl = document.getElementById('keywords-list');

        if (keywords.length === 0) {
            document.getElementById('keywords-empty').classList.remove('hidden');
            return;
        }

        listEl.innerHTML = keywords.map(keyword => `
            <div class="p-6 hover:bg-white/30 transition-all duration-200 group">
                <div class="flex items-start justify-between">
                    <div class="flex-1 min-w-0">
                        <!-- Keyword Header -->
                        <div class="flex items-center space-x-3 mb-3">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-gradient-to-r from-purple-100 to-blue-100 text-purple-800 border border-purple-200">
                                ${keyword.keyword}
                            </span>
                            <span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-medium ${keyword.send_auto_response ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-gray-100 text-gray-600 border border-gray-200'}">
                                ${keyword.send_auto_response ? '✓ Auto-response' : '○ No response'}
                            </span>
                            ${keyword.case_sensitive ? '<span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-medium bg-blue-100 text-blue-700 border border-blue-200">Case sensitive</span>' : ''}
                            ${keyword.exact_match ? '<span class="inline-flex items-center px-2 py-1 rounded-lg text-xs font-medium bg-orange-100 text-orange-700 border border-orange-200">Exact match</span>' : ''}
                        </div>

                        <!-- Description -->
                        ${keyword.description ? `<p class="text-gray-700 text-sm mb-3 leading-relaxed">${keyword.description}</p>` : ''}

                        <!-- Auto Response Preview -->
                        ${keyword.auto_response_message ? `
                            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-3">
                                <p class="text-xs font-medium text-blue-800 mb-1">Auto Response:</p>
                                <p class="text-sm text-blue-700">"${keyword.auto_response_message.length > 100 ? keyword.auto_response_message.substring(0, 100) + '...' : keyword.auto_response_message}"</p>
                            </div>
                        ` : ''}

                        <!-- Stats -->
                        <div class="flex items-center space-x-6 text-xs text-gray-500">
                            <div class="flex items-center space-x-1">
                                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                </svg>
                                <span>${keyword.total_triggers || 0} triggers</span>
                            </div>
                            <div class="flex items-center space-x-1">
                                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/>
                                </svg>
                                <span>${keyword.total_users_captured || 0} users</span>
                            </div>
                            <div class="flex items-center space-x-1">
                                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                                </svg>
                                <span>Type: ${keyword.signup_type || 'general'}</span>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex items-center space-x-2 ml-4 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                        <button onclick="editKeyword(${keyword.id})"
                                class="inline-flex items-center px-3 py-2 bg-blue-100 text-blue-700 text-sm font-medium rounded-lg hover:bg-blue-200 transition-colors">
                            <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                            Edit
                        </button>
                        <button onclick="deleteKeyword(${keyword.id})"
                                class="inline-flex items-center px-3 py-2 bg-red-100 text-red-700 text-sm font-medium rounded-lg hover:bg-red-200 transition-colors">
                            <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    // Edit keyword
    async function editKeyword(keywordId) {
        try {
            const response = await fetch(`/api/integrations/keywords/${keywordId}`);
            const data = await response.json();

            if (data.success) {
                openKeywordFormModal(data.keyword);
            }
        } catch (error) {
            console.error('Error loading keyword:', error);
        }
    }

    // Delete keyword
    async function deleteKeyword(keywordId) {
        if (!confirm('Are you sure you want to delete this keyword?')) {
            return;
        }

        try {
            const response = await fetch(`/api/integrations/keywords/${keywordId}`, {
                method: 'DELETE'
            });

            const data = await response.json();

            if (data.success) {
                loadKeywords(); // Reload the list
            } else {
                alert('Failed to delete keyword: ' + data.error);
            }
        } catch (error) {
            console.error('Error deleting keyword:', error);
            alert('Failed to delete keyword');
        }
    }

    // Populate keyword form with existing data
    function populateKeywordForm(keyword) {
        document.getElementById('keyword-input').value = keyword.keyword || '';
        document.getElementById('keyword-description').value = keyword.description || '';
        document.getElementById('auto-response').value = keyword.auto_response_message || '';
        document.getElementById('case-sensitive').checked = keyword.case_sensitive || false;
        document.getElementById('exact-match').checked = keyword.exact_match || false;
        document.getElementById('send-auto-response').checked = keyword.send_auto_response || false;
        document.getElementById('capture-user-data').checked = keyword.capture_user_data || false;
        document.getElementById('signup-type').value = keyword.signup_type || 'general';
    }

    // Handle keyword form submission
    document.getElementById('keyword-form').addEventListener('submit', async function(e) {
        e.preventDefault();

        const submitBtn = e.target.querySelector('button[type="submit"]');
        const submitText = document.getElementById('keyword-form-submit-text');
        const loadingEl = document.getElementById('keyword-form-loading');

        // Show loading state
        submitBtn.disabled = true;
        submitText.classList.add('hidden');
        loadingEl.classList.remove('hidden');

        try {
            const formData = new FormData(e.target);
            const data = {
                keyword: formData.get('keyword'),
                description: formData.get('description'),
                auto_response_message: formData.get('auto_response_message'),
                case_sensitive: formData.has('case_sensitive'),
                exact_match: formData.has('exact_match'),
                send_auto_response: formData.has('send_auto_response'),
                capture_user_data: formData.has('capture_user_data'),
                signup_type: formData.get('signup_type'),
                social_account_id: currentSocialAccountId,
                keyword_type: 'instagram' // Set the keyword type for Instagram
            };

            console.log('📝 Submitting keyword data:', JSON.stringify(data, null, 2));

            const url = currentEditingKeyword
                ? `/api/integrations/keywords/${currentEditingKeyword.id}`
                : '/api/integrations/keywords';
            const method = currentEditingKeyword ? 'PUT' : 'POST';

            const response = await fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                closeKeywordFormModal();
                loadKeywords(); // Reload the list
                showNotification(currentEditingKeyword ? 'Keyword updated successfully!' : 'Keyword created successfully!', 'success');
            } else {
                alert('Failed to save keyword: ' + result.error);
            }
        } catch (error) {
            console.error('Error saving keyword:', error);
            alert('Failed to save keyword');
        } finally {
            // Reset loading state
            submitBtn.disabled = false;
            submitText.classList.remove('hidden');
            loadingEl.classList.add('hidden');
        }
    });

    // Add event listener for add keyword button (with delay to ensure DOM is ready)
    setTimeout(() => {
        const addBtn = document.getElementById('add-keyword-btn');
        if (addBtn) {
            addBtn.addEventListener('click', function() {
                console.log('Add keyword button clicked');
                openKeywordFormModal();
            });
        } else {
            console.warn('Add keyword button not found in DOM');
        }
    }, 100);

    // Make functions globally available
    window.openKeywordModal = openKeywordModal;
    window.closeKeywordModal = closeKeywordModal;
    window.openKeywordFormModal = openKeywordFormModal;
    window.closeKeywordFormModal = closeKeywordFormModal;
    window.editKeyword = editKeyword;
    window.deleteKeyword = deleteKeyword;

    console.log('✅ Keyword management functions initialized');
});
</script>