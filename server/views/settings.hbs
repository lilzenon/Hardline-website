{{!-- Modern Keyword Management Modal --}}
<div id="keyword-management-modal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <!-- Glassmorphism Background -->
    <div class="fixed inset-0 bg-gradient-to-br from-purple-900/20 via-blue-900/20 to-indigo-900/20 backdrop-blur-md transition-opacity"></div>

    <!-- Modal Container -->
    <div class="flex items-center justify-center min-h-screen p-4">
        <!-- Modal Panel -->
        <div class="relative w-full max-w-4xl bg-white/10 backdrop-blur-xl rounded-3xl border border-white/20 shadow-2xl transform transition-all">
            <!-- Gradient Border Effect -->
            <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-purple-500/20 via-blue-500/20 to-indigo-500/20 p-[1px]">
                <div class="h-full w-full rounded-3xl bg-white/95 backdrop-blur-xl"></div>
            </div>

            <!-- Content -->
            <div class="relative p-8">
                <!-- Header -->
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-2xl font-bold bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
                            Instagram Keywords
                        </h2>
                        <p class="text-gray-600 mt-1">
                            Automate responses to Instagram comments with smart keywords
                        </p>
                    </div>
                    <button type="button" onclick="closeKeywordModal()" class="p-2 rounded-full bg-gray-100 hover:bg-gray-200 transition-colors group">
                        <svg class="h-5 w-5 text-gray-500 group-hover:text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <!-- Add Keyword Button -->
                <div class="mb-6">
                    <button type="button" id="add-keyword-btn" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-600 to-blue-600 text-white font-medium rounded-xl hover:from-purple-700 hover:to-blue-700 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl">
                        <svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
                        </svg>
                        Add New Keyword
                    </button>
                </div>

                <!-- Keywords Container -->
                <div class="bg-white/50 backdrop-blur-sm rounded-2xl border border-white/30 overflow-hidden">
                    <!-- Loading State -->
                    <div id="keywords-loading" class="text-center py-12 hidden">
                        <div class="inline-block animate-spin rounded-full h-10 w-10 border-4 border-purple-200 border-t-purple-600"></div>
                        <p class="mt-4 text-gray-600 font-medium">Loading keywords...</p>
                    </div>

                    <!-- Empty State -->
                    <div id="keywords-empty" class="text-center py-16 hidden">
                        <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-purple-100 to-blue-100 rounded-2xl flex items-center justify-center">
                            <svg class="h-10 w-10 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold text-gray-800 mb-2">No keywords yet</h3>
                        <p class="text-gray-600 mb-6">Create your first keyword to start automating Instagram responses</p>
                        <button type="button" onclick="document.getElementById('add-keyword-btn').click()" class="inline-flex items-center px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">
                            <svg class="h-4 w-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
                            </svg>
                            Create First Keyword
                        </button>
                    </div>

                    <!-- Keywords List -->
                    <div id="keywords-list" class="divide-y divide-white/20">
                        <!-- Keywords will be populated here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

