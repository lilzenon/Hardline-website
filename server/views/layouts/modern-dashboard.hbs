                        </div>
                        <p class="mt-1 text-xs text-gray-500">Auto-generated from title, but you can customize it</p>
                    </div>

                    <!-- Active/Inactive Toggle Switch -->
                    <div class="flex items-center justify-between">
                        <div>
                            <label for="event-active-toggle" class="block text-sm font-medium text-gray-700 mb-1">Event Status</label>
                            <p class="text-xs text-gray-500">Active events are visible to visitors and can collect signups</p>
                        </div>
                        <div class="flex items-center space-x-3">
                            <span class="text-sm text-gray-500" id="toggle-status-text">Active</span>
                            <div class="relative">
                                <!-- Hidden checkbox for form submission -->
                                <input type="checkbox" name="is_active" id="event-active-toggle" value="true" checked class="sr-only">

                                <!-- Custom toggle switch -->
                                <div class="toggle-switch w-12 h-6 bg-primary-600 rounded-full shadow-inner cursor-pointer transition-colors duration-200 ease-in-out"
                                     onclick="toggleEventStatus()"
                                     role="button"
                                     tabindex="0"
                                     aria-label="Toggle event active status"
                                     onkeydown="if(event.key === 'Enter' || event.key === ' ') { event.preventDefault(); toggleEventStatus(); }">
                                    <div class="toggle-dot w-5 h-5 bg-white rounded-full shadow-md transform translate-x-6 transition-transform duration-200 ease-in-out"></div>
