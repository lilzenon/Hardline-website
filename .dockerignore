# ============================================================================
# DOCKER IGNORE - OPTIMIZED FOR FAST BUILDS
# ============================================================================
# Exclude unnecessary files from Docker build context
# This significantly reduces build time and image size
# ============================================================================

# Git and version control
.git
.gitignore
.gitattributes

# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# Build artifacts (will be generated during build)
dist
build

# Development and testing
.env.local
.env.development
.env.test
*.log
logs
coverage/
test/
tests/
__tests__/

# IDE and editor files
.vscode
.idea
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Documentation
README.md
*.md
docs/

# Cache directories
.cache
.eslintcache
tmp/
temp/

# CI/CD files
.github/
docker-compose*.yml
Dockerfile*

# Uploads (mounted as volume)
uploads/

# Development files
.dev/
dev/
