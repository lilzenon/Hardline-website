{
    "name": "kutt",
    "version": "3.2.3",
    "description": "Modern URL shortener.",
    "main": "./server/server.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"node --watch-path=./server --watch-path=./custom server/server.js\"",
        "start": "node server/server.js",
        "build": "npm run build:css && vite build && node scripts/generate-build-info.js",
        "build:css": "npx tailwindcss -i ./src/tailwind.css -o ./static/css/tailwind.css --minify",
        "build:css:dev": "npx tailwindcss -i ./src/tailwind.css -o ./static/css/tailwind.css --watch",


        "migrate": "knex migrate:latest",
        "migrate:make": "knex migrate:make",
        "migrate:crm": "knex migrate:latest --knexfile knexfile.crm.js",
        "migrate:crm:make": "knex migrate:make --knexfile knexfile.crm.js",
        "setup:crm": "node scripts/setup-crm.js",
        "verify:db": "node scripts/verify-database.js",
        "docs:build": "cd docs/api && node generate && cd ../..",
        "build:commit": "node scripts/build-and-commit.js",
        "deploy:prep": "npm run build && npm run build:commit"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thedevs-network/kutt.git"
    },
    "keywords": [
        "url-shortener"
    ],
    "author": "Pouria Ezzati <ezzati.upt@gmail.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/thedevs-network/kutt/issues"
    },
    "homepage": "https://github.com/thedevs-network/kutt#readme",
    "dependencies": {
        "@babel/core": "^7.28.0",
        "@babel/preset-env": "^7.28.0",
        "@babel/preset-react": "^7.27.1",
        "@tanstack/react-query": "^5.84.1",
        "babel-loader": "^10.0.0",
        "bcryptjs": "3.0.2",
        "better-sqlite3": "12.2.0",
        "bull": "4.16.5",
        "bullmq": "^5.56.9",
        "compression": "^1.8.1",
        "connect-redis": "^9.0.0",
        "cookie-parser": "1.4.7",
        "cors": "2.8.5",
        "css-loader": "^7.1.2",
        "date-fns": "4.1.0",
        "dotenv": "17.2.1",
        "envalid": "8.1.0",
        "express": "4.21.2",
